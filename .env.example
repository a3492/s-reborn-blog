# =============================================================
# S-Reborn Blog 환경 변수 템플릿
# 이 파일을 복사해서 사용하세요. 실제 값은 절대 이 파일에 넣지 마세요.
# =============================================================

# ── 클라이언트 공개 변수 ────────────────────────────────────────
# .env 또는 .env.local 에 설정 (Astro 빌드 시 번들에 포함)
PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=

# ── 서버 사이드 비밀 변수 ──────────────────────────────────────
# Cloudflare Pages 대시보드 → Settings → Environment variables 에 설정
# 로컬 개발(wrangler pages dev)은 .dev.vars 파일에 설정
#
# Supabase Service Role (절대 공개 금지)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
#
# GitHub Personal Access Token
# 권한: Contents(Read & Write), Metadata(Read)
# https://github.com/settings/tokens → Fine-grained tokens 권장
# GITHUB_TOKEN=
# GITHUB_REPO=your-org/your-repo   (예: s-reborn/blog-content)
# GITHUB_BRANCH=main               (기본값: main, 생략 가능)
