---
/**
 * Supabase Auth OAuth 기반 댓글 (Google / GitHub / Kakao + 선택 네이버 custom OIDC).
 * 1) 이 마이그레이션 적용: supabase/migrations/20260330_post_comments.sql
 * 2) Dashboard → Authentication → URL: Site URL 및 Redirect URLs에 배포 도메인(예: https://s-reborn-blog.pages.dev/**)
 * 3) Providers에서 Google, GitHub, Kakao 활성화
 * 4) 네이버: Custom OAuth/OIDC 등록 후 PUBLIC_AUTH_ENABLE_NAVER=true, PUBLIC_AUTH_NAVER_PROVIDER_ID(기본 custom:naver)
 * 5) 선택: Apple / Facebook — Dashboard에서 활성화 후 각각 PUBLIC_AUTH_ENABLE_APPLE, PUBLIC_AUTH_ENABLE_FACEBOOK=true
 */
interface Props {
	postPath: string;
}

const { postPath: rawPath } = Astro.props;
const pathKey = (rawPath || '/').replace(/\/$/, '') || '/';
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';
const enableNaver = import.meta.env.PUBLIC_AUTH_ENABLE_NAVER === 'true';
const naverProviderId = (import.meta.env.PUBLIC_AUTH_NAVER_PROVIDER_ID ?? 'custom:naver').trim() || 'custom:naver';
const enableApple = import.meta.env.PUBLIC_AUTH_ENABLE_APPLE === 'true';
const enableFacebook = import.meta.env.PUBLIC_AUTH_ENABLE_FACEBOOK === 'true';
---

<section class="pc-root" aria-labelledby="pc-heading">
	<h2 id="pc-heading" class="pc-title">댓글</h2>
	{
		!supabaseUrl || !supabaseKey ? (
			<p class="pc-muted">댓글을 불러오려면 PUBLIC_SUPABASE_URL과 PUBLIC_SUPABASE_ANON_KEY가 필요합니다.</p>
		) : (
			<>
				<div id="pc-auth" class="pc-auth" hidden>
					<p class="pc-auth-label">로그인 후 댓글을 작성할 수 있습니다.</p>
					<div class="pc-oauth-grid" id="pc-oauth-buttons" />
					<p id="pc-auth-error" class="pc-error" role="alert" hidden />
				</div>
				<div id="pc-user-bar" class="pc-user-bar" hidden>
					<div class="pc-user-meta">
						<img id="pc-avatar" class="pc-avatar" alt="" width="36" height="36" hidden />
						<span id="pc-display-name" class="pc-display-name" />
					</div>
					<button type="button" class="pc-btn pc-btn-ghost" id="pc-sign-out">로그아웃</button>
				</div>
				<form id="pc-form" class="pc-form" hidden>
					<label class="pc-label" for="pc-body">내용</label>
					<textarea
						id="pc-body"
						class="pc-textarea"
						rows="4"
						maxlength="5000"
						placeholder="의견을 입력하세요 (최대 5,000자)"
						required
					/>
					<div class="pc-form-actions">
						<span class="pc-char-count" id="pc-char-count">0 / 5000</span>
						<button type="submit" class="pc-btn pc-btn-primary" id="pc-submit">등록</button>
					</div>
					<p id="pc-form-error" class="pc-error" role="alert" hidden />
				</form>
				<p id="pc-list-status" class="pc-muted" hidden />
				<ul id="pc-list" class="pc-list" />
			</>
		)
	}
</section>

<style>
	.pc-root {
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 1px solid var(--rule);
	}
	.pc-title {
		font-family: var(--display);
		font-size: 1.25rem;
		font-weight: 700;
		color: var(--text);
		margin-bottom: 1rem;
	}
	.pc-muted {
		color: var(--t3);
		font-size: 0.9rem;
	}
	.pc-auth-label {
		color: var(--t2);
		font-size: 0.9rem;
		margin-bottom: 0.75rem;
	}
	.pc-oauth-grid {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.pc-btn-oauth {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.5rem 0.85rem;
		border-radius: 8px;
		border: 1px solid var(--rule);
		background: var(--bg);
		color: var(--text);
		font-family: var(--body);
		font-size: 0.85rem;
		font-weight: 600;
		cursor: pointer;
		transition: background 0.15s, border-color 0.15s;
	}
	.pc-btn-oauth:hover {
		background: var(--bg2);
		border-color: var(--t3);
	}
	.pc-btn-oauth[data-provider='google'] {
		border-color: rgba(66, 133, 244, 0.35);
	}
	.pc-btn-oauth[data-provider='github'] {
		border-color: rgba(36, 41, 47, 0.25);
	}
	.pc-btn-oauth[data-provider='kakao'] {
		background: #fee500;
		border-color: #f0d800;
		color: #191600;
	}
	.pc-btn-oauth[data-provider='apple'] {
		background: #000;
		border-color: #333;
		color: #fff;
	}
	.pc-btn-oauth[data-provider='facebook'] {
		background: #1877f2;
		border-color: #166fe5;
		color: #fff;
	}
	.pc-btn-oauth[data-provider='naver'],
	.pc-btn-oauth[data-provider^='custom:'] {
		background: #03c75a;
		border-color: #02b351;
		color: #fff;
	}
	.pc-user-bar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1rem;
		padding: 0.65rem 0.85rem;
		background: var(--bg2);
		border: 1px solid var(--rule);
		border-radius: 10px;
	}
	.pc-user-meta {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		min-width: 0;
	}
	.pc-avatar {
		border-radius: 50%;
		object-fit: cover;
		flex-shrink: 0;
	}
	.pc-display-name {
		font-weight: 600;
		color: var(--text);
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	.pc-form {
		margin-bottom: 1.5rem;
	}
	.pc-label {
		display: block;
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--t2);
		margin-bottom: 0.35rem;
	}
	.pc-textarea {
		width: 100%;
		padding: 0.65rem 0.75rem;
		border: 1px solid var(--rule);
		border-radius: 8px;
		background: var(--bg);
		color: var(--text);
		font-family: var(--body);
		font-size: 0.95rem;
		resize: vertical;
		min-height: 96px;
	}
	.pc-textarea:focus {
		outline: none;
		border-color: var(--pink);
		box-shadow: 0 0 0 3px var(--pink-lo);
	}
	.pc-form-actions {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-top: 0.5rem;
		gap: 0.75rem;
	}
	.pc-char-count {
		font-size: 0.75rem;
		color: var(--t3);
	}
	.pc-btn {
		font-family: var(--body);
		font-size: 0.85rem;
		font-weight: 600;
		padding: 0.45rem 0.9rem;
		border-radius: 8px;
		cursor: pointer;
		border: 1px solid var(--rule);
		background: var(--bg);
		color: var(--text);
	}
	.pc-btn-primary {
		background: var(--text);
		color: var(--bg);
		border-color: var(--text);
	}
	.pc-btn-primary:disabled {
		opacity: 0.5;
		cursor: not-allowed;
	}
	.pc-btn-ghost {
		background: transparent;
	}
	.pc-error {
		color: #b91c1c;
		font-size: 0.85rem;
		margin-top: 0.5rem;
	}
	.pc-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.pc-item {
		padding: 0.85rem 1rem;
		border: 1px solid var(--rule);
		border-radius: 10px;
		background: var(--bg);
	}
	.pc-item-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
		margin-bottom: 0.5rem;
		flex-wrap: wrap;
	}
	.pc-item-author {
		font-weight: 600;
		color: var(--text);
		font-size: 0.9rem;
	}
	.pc-item-date {
		font-size: 0.75rem;
		color: var(--t3);
	}
	.pc-item-body {
		color: var(--t2);
		font-size: 0.92rem;
		white-space: pre-wrap;
		word-break: break-word;
	}
	.pc-item-actions {
		margin-top: 0.5rem;
	}
	.pc-delete {
		font-size: 0.75rem;
		color: var(--t3);
		background: none;
		border: none;
		cursor: pointer;
		text-decoration: underline;
		padding: 0;
	}
	.pc-delete:hover {
		color: #b91c1c;
	}
</style>

{
	supabaseUrl && supabaseKey && (
		<script
			define:vars={{
				pathKey,
				supabaseUrl,
				supabaseKey,
				enableNaver,
				naverProviderId,
				enableApple,
				enableFacebook,
			}}
		>
			import { createClient } from '@supabase/supabase-js';

			const supabase = createClient(supabaseUrl, supabaseKey, {
				auth: {
					persistSession: true,
					autoRefreshToken: true,
					detectSessionInUrl: true,
				},
			});

			const el = (id) => document.getElementById(id);
			const authWrap = el('pc-auth');
			const oauthHost = el('pc-oauth-buttons');
			const authErr = el('pc-auth-error');
			const userBar = el('pc-user-bar');
			const avatarEl = el('pc-avatar');
			const nameEl = el('pc-display-name');
			const form = el('pc-form');
			const bodyInput = el('pc-body');
			const charCount = el('pc-char-count');
			const formErr = el('pc-form-error');
			const listEl = el('pc-list');
			const listStatus = el('pc-list-status');
			const signOutBtn = el('pc-sign-out');
			const submitBtn = el('pc-submit');

			const redirectTo = () => `${window.location.origin}${window.location.pathname}${window.location.search || ''}`;

			const providers = [
				{ id: 'google', label: 'Google' },
				{ id: 'github', label: 'GitHub' },
				{ id: 'kakao', label: '카카오' },
			];
			if (enableApple) providers.push({ id: 'apple', label: 'Apple' });
			if (enableFacebook) providers.push({ id: 'facebook', label: 'Facebook' });
			if (enableNaver) {
				providers.push({ id: naverProviderId, label: '네이버' });
			}

			const showAuthErr = (msg) => {
				if (!authErr) return;
				authErr.textContent = msg || '';
				authErr.hidden = !msg;
			};

			const showFormErr = (msg) => {
				if (!formErr) return;
				formErr.textContent = msg || '';
				formErr.hidden = !msg;
			};

			const formatDate = (iso) => {
				try {
					const d = new Date(iso);
					return d.toLocaleString('ko-KR', { dateStyle: 'medium', timeStyle: 'short' });
				} catch {
					return iso;
				}
			};

			const renderOAuthButtons = () => {
				if (!oauthHost) return;
				oauthHost.innerHTML = '';
				for (const p of providers) {
					const btn = document.createElement('button');
					btn.type = 'button';
					btn.className = 'pc-btn-oauth';
					btn.dataset.provider = p.id;
					btn.textContent = `${p.label}로 계속하기`;
					btn.addEventListener('click', async () => {
						showAuthErr('');
						const { error } = await supabase.auth.signInWithOAuth({
							provider: p.id,
							options: { redirectTo: redirectTo() },
						});
						if (error) showAuthErr(error.message);
					});
					oauthHost.appendChild(btn);
				}
			};

			const syncCharCount = () => {
				if (!bodyInput || !charCount) return;
				charCount.textContent = `${bodyInput.value.length} / 5000`;
			};

			const loadComments = async () => {
				if (!listEl) return;
				listStatus.hidden = false;
				listStatus.textContent = '댓글을 불러오는 중…';
				const { data, error } = await supabase
					.from('post_comments')
					.select('id, author_name, author_avatar_url, body, created_at, user_id')
					.eq('post_path', pathKey)
					.order('created_at', { ascending: false });

				if (error) {
					listStatus.textContent = `댓글을 불러오지 못했습니다: ${error.message}`;
					listEl.innerHTML = '';
					return;
				}

				listStatus.hidden = true;
				listEl.innerHTML = '';
				if (!data?.length) {
					const li = document.createElement('li');
					li.className = 'pc-muted';
					li.style.listStyle = 'none';
					li.textContent = '아직 댓글이 없습니다. 첫 댓글을 남겨 보세요.';
					listEl.appendChild(li);
					return;
				}

				const session = (await supabase.auth.getSession()).data.session;
				const uid = session?.user?.id;

				for (const row of data) {
					const li = document.createElement('li');
					li.className = 'pc-item';

					const head = document.createElement('div');
					head.className = 'pc-item-head';
					const author = document.createElement('span');
					author.className = 'pc-item-author';
					author.textContent = row.author_name || 'User';
					const date = document.createElement('span');
					date.className = 'pc-item-date';
					date.textContent = formatDate(row.created_at);
					head.append(author, date);

					const body = document.createElement('div');
					body.className = 'pc-item-body';
					body.textContent = row.body;

					li.append(head, body);

					if (uid && row.user_id === uid) {
						const actions = document.createElement('div');
						actions.className = 'pc-item-actions';
						const del = document.createElement('button');
						del.type = 'button';
						del.className = 'pc-delete';
						del.textContent = '삭제';
						del.addEventListener('click', async () => {
							if (!confirm('이 댓글을 삭제할까요?')) return;
							const { error: delErr } = await supabase.from('post_comments').delete().eq('id', row.id);
							if (delErr) {
								alert(delErr.message);
								return;
							}
							await loadComments();
						});
						actions.appendChild(del);
						li.appendChild(actions);
					}

					listEl.appendChild(li);
				}
			};

			const applySession = async (session) => {
				const u = session?.user;
				if (u) {
					if (authWrap) authWrap.hidden = true;
					if (userBar) userBar.hidden = false;
					if (form) form.hidden = false;

					const meta = u.user_metadata || {};
					const name =
						meta.full_name ||
						meta.name ||
						meta.nickname ||
						meta.preferred_username ||
						meta.user_name ||
						u.email?.split('@')[0] ||
						'User';
					if (nameEl) nameEl.textContent = name;

					const av = meta.avatar_url;
					if (avatarEl && av) {
						avatarEl.src = av;
						avatarEl.alt = name;
						avatarEl.hidden = false;
					} else if (avatarEl) {
						avatarEl.removeAttribute('src');
						avatarEl.hidden = true;
					}
				} else {
					if (authWrap) authWrap.hidden = false;
					if (userBar) userBar.hidden = true;
					if (form) form.hidden = true;
					if (avatarEl) avatarEl.hidden = true;
				}
				await loadComments();
			};

			renderOAuthButtons();
			syncCharCount();
			bodyInput?.addEventListener('input', syncCharCount);

			supabase.auth.onAuthStateChange((_event, session) => {
				applySession(session);
			});

			const { data: initial } = await supabase.auth.getSession();
			await applySession(initial.session);

			signOutBtn?.addEventListener('click', async () => {
				await supabase.auth.signOut();
			});

			form?.addEventListener('submit', async (e) => {
				e.preventDefault();
				showFormErr('');
				const text = (bodyInput?.value || '').trim();
				if (!text) {
					showFormErr('내용을 입력해 주세요.');
					return;
				}
				const { data: s } = await supabase.auth.getSession();
				const user = s.session?.user;
				if (!user) {
					showFormErr('로그인이 필요합니다.');
					return;
				}
				if (submitBtn) submitBtn.disabled = true;
				const { error } = await supabase.from('post_comments').insert({
					post_path: pathKey,
					user_id: user.id,
					body: text,
				});
				if (submitBtn) submitBtn.disabled = false;
				if (error) {
					showFormErr(error.message);
					return;
				}
				if (bodyInput) bodyInput.value = '';
				syncCharCount();
				await loadComments();
			});
		</script>
	)
}
