---
interface Props {
	slug: string;
}
const { slug } = Astro.props;

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<div class="post-stats">
	<span class="stat">
		<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
			<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
			<circle cx="12" cy="12" r="3"/>
		</svg>
		<span id="view-count">…</span>
	</span>
	<button id="like-btn" class="stat like-btn" aria-label="좋아요">
		<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
			<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
		</svg>
		<span id="like-count">…</span>
	</button>
</div>

<style>
	.post-stats {
		display: flex;
		gap: 1.2rem;
		align-items: center;
		justify-content: center;
		margin: 0.25rem 0 1.25rem;
		color: rgb(var(--gray));
		font-size: 0.875rem;
	}
	.stat {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
	}
	.like-btn {
		background: none;
		border: none;
		cursor: pointer;
		color: rgb(var(--gray));
		padding: 0;
		font-size: 0.875rem;
		transition: color 0.15s, transform 0.1s;
	}
	.like-btn:hover { color: #e74c3c; }
	.like-btn.liked { color: #e74c3c; }
	.like-btn.liked svg { fill: #e74c3c; stroke: #e74c3c; }
	.like-btn:active { transform: scale(1.3); }
</style>

<script define:vars={{ slug, supabaseUrl, supabaseKey }}>
	const headers = {
		apikey: supabaseKey,
		Authorization: `Bearer ${supabaseKey}`,
		'Content-Type': 'application/json',
	};

	async function rpc(fn, body) {
		const res = await fetch(`${supabaseUrl}/rest/v1/rpc/${fn}`, {
			method: 'POST',
			headers,
			body: JSON.stringify(body),
		});
		return res.ok ? res.json() : null;
	}

	async function get(table) {
		const res = await fetch(
			`${supabaseUrl}/rest/v1/${table}?slug=eq.${encodeURIComponent(slug)}&select=count`,
			{ headers }
		);
		const data = res.ok ? await res.json() : [];
		return data?.[0]?.count ?? 0;
	}

	async function loadStats() {
		const [views, likes] = await Promise.all([get('post_views'), get('post_likes')]);
		document.getElementById('view-count').textContent = views;
		document.getElementById('like-count').textContent = likes;
	}

	async function incrementView() {
		if (sessionStorage.getItem(`v_${slug}`)) return;
		sessionStorage.setItem(`v_${slug}`, '1');
		await rpc('increment_view', { p_slug: slug });
		const el = document.getElementById('view-count');
		if (el && el.textContent !== '…') el.textContent = parseInt(el.textContent) + 1;
	}

	async function toggleLike() {
		const key = `l_${slug}`;
		const liked = localStorage.getItem(key);
		const btn = document.getElementById('like-btn');
		const el = document.getElementById('like-count');
		const current = parseInt(el.textContent) || 0;

		if (liked) {
			localStorage.removeItem(key);
			btn.classList.remove('liked');
			el.textContent = Math.max(0, current - 1);
			await rpc('decrement_like', { p_slug: slug });
		} else {
			localStorage.setItem(key, '1');
			btn.classList.add('liked');
			el.textContent = current + 1;
			await rpc('increment_like', { p_slug: slug });
		}
	}

	// 초기화
	loadStats().then(() => incrementView());

	if (localStorage.getItem(`l_${slug}`)) {
		document.getElementById('like-btn')?.classList.add('liked');
	}

	document.getElementById('like-btn')?.addEventListener('click', toggleLike);
</script>
