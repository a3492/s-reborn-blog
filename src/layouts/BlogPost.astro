---
import '../styles/design.css';
import '../styles/global.css';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import GiscusComments from '../components/GiscusComments.astro';
import Topbar from '../components/Topbar.astro';
import PostStats from '../components/PostStats.astro';
import { CATEGORIES } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { slug?: string };

const { title, description, date, thumbnail, category, tags } = Astro.props;
const slug = Astro.url.pathname.replace(/^\/blog\//, '').replace(/\/$/, '');

const pageUrl = Astro.url.href;
const encodedUrl = encodeURIComponent(pageUrl);
const encodedTitle = encodeURIComponent(title);

const shareLinks = {
	twitter: `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`,
	linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`,
	kakao: null,
};
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} image={thumbnail} />
	</head>

	<body class="blog-post-shell">
		<Topbar />
		<main class="blog-post-main">
			<article class="blog-post-article">
				{thumbnail && (
					<div class="blog-post-hero">
						<img src={thumbnail} alt={title} />
					</div>
				)}
				<div class="blog-post-prose prose">
					<div class="blog-post-title title">
						<div class="blog-post-meta meta">
							{category && (
								<span class="blog-post-category category-badge">
									{CATEGORIES.find(c => c.id === category)?.label ?? category}
								</span>
							)}
							<FormattedDate date={date} />
						</div>
						<h1>{title}</h1>
						{tags && tags.length > 0 && (
							<div class="blog-post-tags tags">
								{tags.map((tag) => <span class="blog-post-tag tag">#{tag}</span>)}
							</div>
						)}
						<PostStats slug={slug} />
						<hr />
					</div>
					<slot />

					<div class="blog-post-share-section share-section">
						<p>이 글이 도움이 됐다면 링크를 남겨 두거나 바로 공유할 수 있습니다.</p>
						<div class="blog-post-share-buttons share-buttons">
							<a
								href={shareLinks.twitter}
								target="_blank"
								rel="noopener noreferrer"
								class="blog-post-share-btn share-btn twitter"
							>
								𝕏 트위터
							</a>
							<a
								href={shareLinks.linkedin}
								target="_blank"
								rel="noopener noreferrer"
								class="blog-post-share-btn share-btn linkedin"
							>
								LinkedIn
							</a>
							<button
								id="kakao-share-btn"
								class="blog-post-share-btn share-btn kakao"
								type="button"
							>
								카카오톡
							</button>
							<button
								id="copy-link-btn"
								class="blog-post-share-btn share-btn copy"
								type="button"
							>
								링크 복사
							</button>
						</div>
						<p id="share-feedback" class="blog-post-share-feedback" aria-live="polite"></p>
					</div>

					<GiscusComments />
				</div>
			</article>
		</main>
		<Footer />

		<script define:vars={{ pageUrl, title }}>
			const copyButton = document.getElementById('copy-link-btn');
			const kakaoButton = document.getElementById('kakao-share-btn');
			const feedback = document.getElementById('share-feedback');

			const setFeedback = (text) => {
				if (!feedback) return;
				feedback.textContent = text;
			};

			copyButton?.addEventListener('click', async () => {
				try {
					await navigator.clipboard.writeText(pageUrl);
					if (copyButton) {
						copyButton.textContent = '복사됨!';
						setTimeout(() => { copyButton.textContent = '링크 복사'; }, 2000);
					}
					setFeedback('현재 글 링크를 클립보드에 복사했습니다.');
				} catch {
					setFeedback('링크 복사에 실패했습니다. 브라우저 권한을 확인해 주세요.');
				}
			});

			kakaoButton?.addEventListener('click', async () => {
				if (typeof Kakao !== 'undefined' && Kakao.isInitialized()) {
					Kakao.Share.sendDefault({
						objectType: 'feed',
						content: {
							title: title,
							webUrl: pageUrl,
							mobileWebUrl: pageUrl,
						},
					});
					setFeedback('카카오톡 공유 창을 열었습니다.');
					return;
				}

				try {
					await navigator.clipboard.writeText(pageUrl);
					setFeedback('카카오 SDK가 없어 링크를 대신 복사했습니다. 카카오톡에 붙여넣어 공유할 수 있습니다.');
				} catch {
					setFeedback('카카오 공유를 열 수 없고 링크 복사에도 실패했습니다.');
				}
			});
		</script>
	</body>
</html>
