---
import '../styles/design.css';
import '../styles/global.css';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import GiscusComments from '../components/GiscusComments.astro';
import Topbar from '../components/Topbar.astro';
import PostStats from '../components/PostStats.astro';
import { CATEGORIES } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { slug?: string };

const { title, description, date, thumbnail, category, tags } = Astro.props;
const slug = Astro.url.pathname.replace(/^\/blog\//, '').replace(/\/$/, '');

const pageUrl = Astro.url.href;
const encodedUrl = encodeURIComponent(pageUrl);
const encodedTitle = encodeURIComponent(title);

const shareLinks = {
	twitter: `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`,
	linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`,
	kakao: null,
};
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} image={thumbnail} />
	</head>

	<body class="blog-post-shell">
		<Topbar />
		<main class="blog-post-main">
			<article class="blog-post-article">
				{thumbnail && (
					<div class="blog-post-hero">
						<img src={thumbnail} alt={title} />
					</div>
				)}
				<div class="blog-post-prose prose">
					<div class="blog-post-title title">
						<div class="blog-post-meta meta">
							{category && (
								<span class="blog-post-category category-badge">
									{CATEGORIES.find(c => c.id === category)?.label ?? category}
								</span>
							)}
							<FormattedDate date={date} />
						</div>
						<h1>{title}</h1>
						{tags && tags.length > 0 && (
							<div class="blog-post-tags tags">
								{tags.map((tag) => <span class="blog-post-tag tag">#{tag}</span>)}
							</div>
						)}
						<PostStats slug={slug} />
						<hr />
					</div>
					<slot />

					<div class="blog-post-share-section share-section">
						<p>이 글이 도움이 됐나요? 공유해 주세요.</p>
						<div class="blog-post-share-buttons share-buttons">
							<a
								href={shareLinks.twitter}
								target="_blank"
								rel="noopener noreferrer"
								class="blog-post-share-btn share-btn twitter"
							>
								𝕏 트위터
							</a>
							<a
								href={shareLinks.linkedin}
								target="_blank"
								rel="noopener noreferrer"
								class="blog-post-share-btn share-btn linkedin"
							>
								LinkedIn
							</a>
							<button
								id="kakao-share-btn"
								class="blog-post-share-btn share-btn kakao"
							>
								카카오톡
							</button>
							<button
								id="copy-link-btn"
								class="blog-post-share-btn share-btn copy"
							>
								링크 복사
							</button>
						</div>
					</div>

					<GiscusComments />
				</div>
			</article>
		</main>
		<Footer />

		<script define:vars={{ pageUrl, title }}>
			document.getElementById('copy-link-btn')?.addEventListener('click', () => {
				navigator.clipboard.writeText(pageUrl).then(() => {
					const btn = document.getElementById('copy-link-btn');
					if (btn) {
						btn.textContent = '복사됨!';
						setTimeout(() => { btn.textContent = '링크 복사'; }, 2000);
					}
				});
			});

			document.getElementById('kakao-share-btn')?.addEventListener('click', () => {
				if (typeof Kakao !== 'undefined' && Kakao.isInitialized()) {
					Kakao.Share.sendDefault({
						objectType: 'feed',
						content: {
							title: title,
							webUrl: pageUrl,
							mobileWebUrl: pageUrl,
						},
					});
				} else {
					navigator.clipboard.writeText(pageUrl).then(() => {
						alert('카카오 SDK 미설치 상태입니다. 링크가 복사되었습니다.\n카카오톡에서 직접 붙여넣어 공유하세요.');
					});
				}
			});

			document.addEventListener('contextmenu', (e) => e.preventDefault());
			document.addEventListener('selectstart', (e) => {
				const target = e.target;
				if (target.tagName === 'INPUT' || target.tagName === 'TEXTAREA') return;
				e.preventDefault();
			});
			document.addEventListener('dragstart', (e) => e.preventDefault());
			document.addEventListener('keydown', (e) => {
				if (
					(e.ctrlKey && ['c', 's', 'u'].includes(e.key.toLowerCase())) ||
					e.key === 'F12' ||
					(e.ctrlKey && e.shiftKey && e.key.toLowerCase() === 'i')
				) {
					e.preventDefault();
				}
			});
		</script>
	</body>
</html>
