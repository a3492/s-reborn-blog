---
import '../styles/design.css';
import '../styles/global.css';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Topbar from '../components/Topbar.astro';
import PostStats from '../components/PostStats.astro';
import { CATEGORIES, MENU_GROUPS } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { slug?: string; lang?: 'ko' | 'en'; title_en?: string; description_en?: string };

const { title, title_en, description, description_en, date, thumbnail, category, tags, lang = 'ko' } = Astro.props;
const isEn = lang === 'en';
const displayTitle = isEn && title_en ? title_en : title;
const displayDescription = isEn && description_en ? description_en : description;
const slug = Astro.url.pathname.replace(/^\/(?:en\/)?blog\//, '').replace(/\/$/, '');

// 카테고리별 글 수 (네비용)
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const countsByCategory = allPosts.reduce<Record<string, number>>((acc, post) => {
	const c = post.data.category;
	if (c) acc[c] = (acc[c] ?? 0) + 1;
	return acc;
}, {});
---

<html lang={lang}>
	<head>
		<BaseHead title={displayTitle} description={displayDescription} image={thumbnail} />
	</head>

	<body class="blog-post-shell">
		<div class="site-wrap">
		<Topbar lang={lang} />
		<div class="site-main">
		<div class="blog-layout">

			<!-- ── 좌측 네비게이션 ── -->
			<nav class="blog-nav" id="blog-nav" aria-label="카테고리 내비게이션">

				<!-- 모바일 토글 -->
				<button class="blog-nav-mobile-toggle" id="blog-nav-toggle" aria-expanded="false">
					<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
						<path d="M2 4h12M2 8h12M2 12h12"/>
					</svg>
					<span>{isEn ? 'Categories' : '카테고리'}</span>
					<svg class="blog-nav-mobile-chevron" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M3 1.5l4 3.5-4 3.5"/></svg>
				</button>

				<div class="blog-nav-body" id="blog-nav-body">
					<!-- 전체 -->
					<a class="blog-nav-all" href={isEn ? '/en/blog/' : '/blog/'} data-navlink>
						<span class="blog-nav-all-label">{isEn ? '⊞ All Posts' : '⊞ 전체 글'}</span>
						<span class="blog-nav-count">{allPosts.length}</span>
					</a>

					<div class="blog-nav-divider"></div>

					<!-- 그룹 -->
					{MENU_GROUPS.map((group) => {
						const isActiveGroup = group.cats.includes(category as any);
						const groupLabel = isEn ? group.labelEn : group.label;
						return (
							<div class={`blog-nav-group${isActiveGroup ? ' is-open' : ''}`} data-group={group.id}>
								<button class="blog-nav-group-hd" data-toggle={group.id}>
									<span class="blog-nav-group-icon">{group.icon}</span>
									<span class="blog-nav-group-label">{groupLabel}</span>
									<svg class="blog-nav-chevron" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
										<path d="M3 1.5l4 3.5-4 3.5"/>
									</svg>
								</button>
								<div class="blog-nav-group-body">
									{group.cats.map((catId) => {
										const cat = CATEGORIES.find((c) => c.id === catId);
										if (!cat) return null;
										const count = countsByCategory[catId] ?? 0;
										const isActive = catId === category;
										const catLabel = isEn ? cat.labelEn : cat.label;
										const catHref = isEn ? `/en/blog/?category=${catId}` : `/blog/?category=${catId}`;
										return (
											<a
												class={`blog-nav-item${isActive ? ' blog-nav-item--active' : ''}`}
												href={catHref}
											>
												<span class="blog-nav-item-label">{catLabel}</span>
												<span class="blog-nav-item-count">{count}</span>
											</a>
										);
									})}
								</div>
							</div>
						);
					})}
				</div>
			</nav>

			<!-- ── 글 본문 ── -->
			<main class="blog-content blog-post-main">
				<article class="blog-post-article">
					{thumbnail && (
						<div class="blog-post-hero">
							<img src={thumbnail} alt={title} />
						</div>
					)}
					<div class="blog-post-prose prose">
						<div class="blog-post-title title">
							<div class="blog-post-meta meta">
								{category && (
									<span class="blog-post-category category-badge">
										{(() => { const c = CATEGORIES.find(x => x.id === category); return isEn ? (c?.labelEn ?? category) : (c?.label ?? category); })()}
									</span>
								)}
								<FormattedDate date={date} />
							</div>
							<h1>{displayTitle}</h1>
							<PostStats slug={slug} />
							<hr />
						</div>
						<slot />

						{tags && tags.length > 0 && (
							<div class="blog-post-tags blog-post-tags--after-body tags" aria-label="태그">
								{tags.map((tag) => <span class="blog-post-tag tag">#{tag}</span>)}
							</div>
						)}

					</div>
				</article>
			</main>
		</div>

		</div><!-- /.blog-layout -->
		</div><!-- /.site-main -->
		<Footer />

		<script is:inline>
			// 그룹 펼치기/접기
			document.querySelectorAll('.blog-nav-group-hd').forEach(function(hd) {
				hd.addEventListener('click', function() {
					hd.closest('.blog-nav-group').classList.toggle('is-open');
				});
			});

			// 모바일 토글
			var mobileToggle = document.getElementById('blog-nav-toggle');
			var navBody = document.getElementById('blog-nav-body');
			if (mobileToggle && navBody) {
				mobileToggle.addEventListener('click', function() {
					var open = navBody.classList.toggle('is-open');
					mobileToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
				});
			}
		</script>
		</div><!-- /.site-wrap -->
	</body>
</html>
