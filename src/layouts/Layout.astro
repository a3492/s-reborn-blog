---
import '../styles/design.css';
import BaseHead from '../components/BaseHead.astro';
import Topbar from '../components/Topbar.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION, CONTACT_EMAIL } from '../consts';
import { getCollection } from 'astro:content';
import { getPublicSiteSettings } from '../lib/site-settings';

interface Props {
	title?: string;
	description?: string;
}

const { title, description = SITE_DESCRIPTION } = Astro.props;
const siteSettings = await getPublicSiteSettings();
const resolvedSiteTitle = siteSettings.siteTitle || SITE_TITLE;
const resolvedDescription = description || siteSettings.siteDescription || SITE_DESCRIPTION;

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const searchIndex = allPosts.map(post => ({
  id: post.id,
  title: post.data.title,
  description: post.data.description ?? '',
  category: post.data.category ?? '',
  tags: (post.data.tags ?? []).join(' '),
  difficulty: post.data.difficulty ?? '',
  type: post.data.type ?? '',
  subcategory: post.data.subcategory ?? '',
  url: `/blog/${post.id}/`,
  // 재정렬용 원본 값
  _difficulty: post.data.difficulty ?? '',
  _tags: post.data.tags ?? [],
}));
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead
      title={title ? `${title} | ${resolvedSiteTitle}` : resolvedSiteTitle}
      description={resolvedDescription}
      image={siteSettings.defaultOgImage || undefined}
      siteTitle={resolvedSiteTitle}
    />
	</head>
	<body>
		<div class="site-wrap">
			<Topbar siteTitle={resolvedSiteTitle} />
			<main class="site-main">
				<slot />
			</main>
			<Footer siteTitle={resolvedSiteTitle} socialLinks={siteSettings.socialLinks} />
		</div>

		<script define:vars={{ searchIndex, contactEmail: CONTACT_EMAIL, supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL ?? '', supabaseKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '' }}>
		(function() {
      const input = document.getElementById('search-input');
      const wrap = document.querySelector('[data-search-wrap]');
      const dropdown = document.getElementById('search-dropdown');
      const resultsEl = document.getElementById('search-results');
      const emptyEl = document.getElementById('search-empty');
      const statusEl    = document.getElementById('search-status');
      const requestBtn  = document.getElementById('request-article-btn');
      const requestDone = document.getElementById('request-done');

      if (!input || !dropdown || !wrap || !resultsEl || !emptyEl || !statusEl) return;

      // ─────────────────────────────────────────────────────────────
      // 의미 확장 사전 — 사용자 의도 키워드 → 관련 개념으로 확장
      // "입문"을 검색하면 difficulty:beginner 글도 같이 찾아줌
      // ─────────────────────────────────────────────────────────────
      const CONCEPT_MAP = {
        // 난이도·수준
        '입문':     ['beginner', '초보', '기초', '처음', '시작', '도구소개', '쉬운', 'FAQ', '설치'],
        '초보':     ['beginner', '입문', '기초', '처음', '쉬운', '시작'],
        '기초':     ['beginner', '입문', '초보', '기본', '처음'],
        '쉬운':     ['beginner', '입문', '초보', '기초', '간단'],
        '시작':     ['beginner', '입문', '초보', '설치', '처음'],
        '처음':     ['beginner', '입문', '초보', '기초', '시작'],
        '심화':     ['advanced', '고급', '전문', 'intermediate', '깊이'],
        '고급':     ['advanced', '심화', '전문', '깊이'],
        '중급':     ['intermediate', '중간'],
        '전문':     ['advanced', '심화', '고급', '의료'],
        // 비용
        '비용':     ['무료', '유료', '가격', '요금', 'API', '구독', '결제', 'cost'],
        '무료':     ['free', '비용', '가격', '요금'],
        '가격':     ['비용', '무료', '유료', '요금', '구독'],
        '유료':     ['비용', '가격', '결제', '구독'],
        '돈':       ['비용', '가격', '요금', '무료', '유료'],
        '요금':     ['비용', '가격', '무료', '유료', '구독'],
        '구독':     ['비용', '가격', '유료', '결제', '플랜'],
        // 법·책임·윤리
        '법':       ['법적', '법률', '의료법', '규정', '합법', '책임', '허가'],
        '법적':     ['법', '법률', '의료법', '규정', '합법', '책임'],
        '법률':     ['법', '법적', '의료법', '규정', '책임'],
        '규정':     ['법', '법적', '법률', '의료법', '허가'],
        '책임':     ['법적', '의사', '오류', '과실', '법률'],
        '윤리':     ['법적', '도덕', '책임', '동의', '허가', '환자'],
        '허가':     ['법적', '규정', '의료법', '승인'],
        '합법':     ['법', '법적', '허가', '규정'],
        '동의':     ['환자', '허가', '법적', '윤리'],
        '과실':     ['책임', '오류', '법적', '의사'],
        // 보안·개인정보
        '보안':     ['개인정보', '데이터', '보호', 'GDPR', '암호화', '프라이버시'],
        '개인정보': ['보안', '데이터', '보호', 'GDPR', '환자', '프라이버시'],
        '데이터':   ['개인정보', '보안', '보호', '환자', '의료'],
        'GDPR':     ['개인정보', '보안', '보호', '규정'],
        '프라이버시':['보안', '개인정보', '보호'],
        // 의료·임상
        '진단':     ['AI', '의료', '의사', '임상', '병원'],
        '의사':     ['의료', '임상', '진료', '병원', '처방'],
        '병원':     ['의료', '임상', '의사', '진료'],
        '환자':     ['의료', '임상', '진료', '개인정보'],
        '처방':     ['의사', '진료', '의약품', '약물'],
        '임상':     ['의료', '의사', '진료', '병원'],
        '진료':     ['의사', '임상', '병원', '환자'],
        '약':       ['의약품', '처방', '약물', '의사'],
        '의약품':   ['약', '처방', '약물', '의사'],
        // AI·자동화·도구
        '도구':     ['툴', '소프트웨어', 'AI', '앱', '플랫폼', '도구소개'],
        '설치':     ['install', '셋업', '시작', '준비', '환경'],
        'AI':       ['인공지능', 'LLM', 'GPT', 'Claude', '생성형'],
        '자동화':   ['workflow', '파이프라인', '에이전트', '오케스트레이션'],
        '글쓰기':   ['문서', '기록', '작성', '노트', '보고서'],
        '요약':     ['정리', '분석', '추출', '핵심'],
        '번역':     ['언어', '영어', '변환', '다국어'],
        '검색':     ['탐색', '찾기', '조회', '리서치', 'search'],
        '분석':     ['요약', '검토', '평가', '정리'],
        '코딩':     ['개발', '프로그래밍', '코드', '소프트웨어'],
        '개발':     ['코딩', '프로그래밍', '소프트웨어', '앱'],
        // 특정 도구명
        'ChatGPT':  ['GPT', 'OpenAI', 'AI', '음성'],
        'Claude':   ['Anthropic', 'AI', 'LLM', 'Claude Code'],
        'Codex':    ['OpenAI', 'CLI', '코딩', '개발', '터미널'],
        'Cursor':   ['IDE', '코딩', '에디터', '개발', 'AI'],
        'Copilot':  ['GitHub', 'AI', '코딩', '자동완성'],
        '터미널':   ['CLI', '명령어', '설치', '개발'],
        '에디터':   ['IDE', 'Cursor', 'VS Code', '코딩'],
      };

      // 쿼리에서 확장 용어 목록 반환
      const expandQuery = (query) => {
        const q = query.toLowerCase().trim();
        const terms = new Set([q]);
        for (const [key, synonyms] of Object.entries(CONCEPT_MAP)) {
          const k = key.toLowerCase();
          if (q.includes(k) || k.includes(q)) {
            synonyms.forEach(s => terms.add(s.toLowerCase()));
            terms.add(k);
          }
          if (synonyms.some(s => {
            const sl = s.toLowerCase();
            return q.includes(sl) || sl.includes(q);
          })) {
            terms.add(k);
            synonyms.forEach(s => terms.add(s.toLowerCase()));
          }
        }
        return [...terms];
      };

      // 쿼리에서 난이도 의도 감지
      const detectIntent = (query) => {
        const q = query.toLowerCase();
        if (['입문', '초보', '기초', '쉬운', '처음', '시작', 'beginner'].some(t => q.includes(t))) return 'beginner';
        if (['심화', '고급', '전문', 'advanced'].some(t => q.includes(t))) return 'advanced';
        if (['중급', 'intermediate'].some(t => q.includes(t))) return 'intermediate';
        return null;
      };

      let fuse = null;
      let activeIndex = -1;
      let renderedItems = [];

      const setExpanded = (v) => input.setAttribute('aria-expanded', v ? 'true' : 'false');
      const setStatus = (text, visible) => {
        statusEl.textContent = text;
        statusEl.classList.toggle('hidden', !visible);
      };
      const positionDropdown = () => {
        const rect = wrap.getBoundingClientRect();
        dropdown.style.width = `${rect.width}px`;
        dropdown.style.left = `${rect.left}px`;
        dropdown.style.top = `${rect.bottom + 8}px`;
      };
      const showDropdown = () => { positionDropdown(); dropdown.classList.remove('hidden'); setExpanded(true); };
      const hideDropdown = () => {
        dropdown.classList.add('hidden'); setExpanded(false);
        activeIndex = -1; input.setAttribute('aria-activedescendant', '');
      };
      const syncActiveItem = () => {
        renderedItems.forEach((item, i) => {
          item.classList.toggle('is-active', i === activeIndex);
          if (i === activeIndex) { input.setAttribute('aria-activedescendant', item.id); item.scrollIntoView({ block: 'nearest' }); }
        });
        if (activeIndex < 0) input.setAttribute('aria-activedescendant', '');
      };

      // 단일 용어로 검색 (Fuse 또는 fallback)
      const searchTerm = (term) => {
        if (fuse) return fuse.search(term);
        const tl = term.toLowerCase();
        return searchIndex
          .filter(p => [p.title, p.description, p.category, p.tags, p.difficulty, p.type]
            .some(f => f?.toLowerCase().includes(tl)))
          .map(item => ({ item, score: 0.4 }));
      };

      // 의미 기반 검색 — 개념 확장 + 난이도 재정렬
      const semanticSearch = (query) => {
        const terms = expandQuery(query);
        const intent = detectIntent(query);

        // 1차: 원본 쿼리로 검색
        const primary = searchTerm(query);
        const seen = new Set(primary.map(r => r.item.id));
        const expanded = [];

        // 2차: 확장 용어로 추가 검색
        for (const term of terms.slice(1)) {
          if (term.length < 2) continue;
          for (const r of searchTerm(term)) {
            if (!seen.has(r.item.id)) {
              seen.add(r.item.id);
              expanded.push({ ...r, _expanded: true });
            }
          }
        }

        const merged = [
          ...primary.map(r => ({ ...r, _expanded: false })),
          ...expanded,
        ];

        // 3차: 난이도 의도가 있으면 재정렬
        if (intent) {
          merged.sort((a, b) => {
            const aM = a.item._difficulty === intent;
            const bM = b.item._difficulty === intent;
            if (aM !== bM) return aM ? -1 : 1;
            if (a._expanded !== b._expanded) return a._expanded ? 1 : -1;
            return (a.score ?? 0.5) - (b.score ?? 0.5);
          });
        }

        return merged;
      };

      const DIFF_LABEL = { beginner: '입문', intermediate: '중급', advanced: '고급' };
      const DIFF_KOR = { beginner: '입문자용', intermediate: '중급자용', advanced: '고급자용' };

      const renderResults = (query) => {
        const normalized = query.trim();
        if (!normalized) {
          resultsEl.innerHTML = '';
          emptyEl.classList.add('hidden');
          hideDropdown();
          return;
        }

        const results = semanticSearch(normalized).slice(0, 8);
        resultsEl.innerHTML = '';
        renderedItems = [];
        activeIndex = -1;

        if (results.length > 0) {
          emptyEl.classList.add('hidden');
          resultsEl.classList.remove('hidden');
          results.forEach(({ item, _expanded }, index) => {
            const a = document.createElement('a');
            a.className = 'search-result-item';
            a.href = item.url;
            a.id = `search-result-${index}`;
            a.setAttribute('role', 'option');

            const diffLabel = DIFF_LABEL[item._difficulty] || '';
            const diffTitle = DIFF_KOR[item._difficulty] || '';

            a.innerHTML = `
              <div class="sr-meta">
                ${item.category ? `<span class="sr-cat">${item.category}</span>` : ''}
                ${diffLabel ? `<span class="sr-diff sr-diff--${item._difficulty}" title="${diffTitle}">${diffLabel}</span>` : ''}
                ${_expanded ? `<span class="sr-semantic-badge">연관</span>` : ''}
              </div>
              <span class="sr-title">${item.title}</span>
              ${item.description ? `<span class="sr-desc">${item.description}</span>` : ''}
            `;
            a.addEventListener('mouseenter', () => { activeIndex = index; syncActiveItem(); });
            resultsEl.appendChild(a);
            renderedItems.push(a);
          });
        } else {
          resultsEl.classList.add('hidden');
          emptyEl.classList.remove('hidden');
          if (requestBtn) requestBtn.dataset.query = normalized;
        }

        showDropdown();
      };

      // Fuse.js CDN 로드 — tags·difficulty·type까지 포함한 가중치 검색
      // weight는 Fuse.js 스펙상 0~1 사이 값이어야 함 (초과 시 스코어 계산 오작동)
      const FUSE_CDN = 'https://cdn.jsdelivr.net/npm/fuse.js@7.1.0/dist/fuse.mjs';
      const buildFuse = (Fuse) => new Fuse(searchIndex, {
        keys: [
          { name: 'title',       weight: 1   },
          { name: 'tags',        weight: 0.8 },
          { name: 'description', weight: 0.6 },
          { name: 'difficulty',  weight: 0.4 },
          { name: 'category',    weight: 0.4 },
          { name: 'subcategory', weight: 0.3 },
          { name: 'type',        weight: 0.2 },
        ],
        threshold: 0.35,
        minMatchCharLength: 1,
        includeScore: true,
      });
      setStatus('검색 인덱스를 준비하는 중입니다...', true);
      import(FUSE_CDN)
        .then((m) => {
          fuse = buildFuse(m.default);
          setStatus('', false);
        })
        .catch(() => {
          // CDN 실패 시 fallback: includes 검색
          fuse = {
            search: (q) => {
              const ql = q.toLowerCase();
              return searchIndex
                .filter(p => [p.title, p.description, p.category, p.tags, p.difficulty]
                  .some(f => f?.toLowerCase().includes(ql)))
                .map(item => ({ item, score: 0.3 }));
            },
          };
          setStatus('', false);
        });

      let timer;
      input.addEventListener('input', (e) => {
        clearTimeout(timer);
        timer = setTimeout(() => renderResults(e.target.value), 120);
      });

      input.addEventListener('focus', () => {
        if (input.value.trim()) renderResults(input.value);
      });

      input.addEventListener('keydown', (e) => {
        // Enter는 드롭다운 상태와 무관하게 항상 처리
        if (e.key === 'Enter') {
          e.preventDefault();
          if (activeIndex >= 0 && renderedItems[activeIndex]) {
            renderedItems[activeIndex].click();
          } else {
            const q = input.value.trim();
            if (q) window.location.href = `/blog?q=${encodeURIComponent(q)}`;
          }
          return;
        }
        // 화살표는 드롭다운이 열렸을 때만
        if (dropdown.classList.contains('hidden')) return;
        if (e.key === 'ArrowDown') { e.preventDefault(); activeIndex = Math.min(renderedItems.length - 1, activeIndex + 1); syncActiveItem(); }
        if (e.key === 'ArrowUp')   { e.preventDefault(); activeIndex = Math.max(0, activeIndex - 1); syncActiveItem(); }
      });

      document.addEventListener('click', (e) => {
        if (!dropdown.contains(e.target) && !wrap.contains(e.target)) hideDropdown();
      });

      document.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') { e.preventDefault(); input.focus(); input.select(); }
        if (e.key === 'Escape') { hideDropdown(); input.blur(); }
      });

      window.addEventListener('resize', () => { if (!dropdown.classList.contains('hidden')) positionDropdown(); });
      window.addEventListener('scroll', () => { if (!dropdown.classList.contains('hidden')) positionDropdown(); }, true);

      if (requestBtn) {
        requestBtn.addEventListener('click', async () => {
          const query = requestBtn.dataset.query || input.value.trim();
          if (!query) return;

          // 즉시 완료 상태로 전환 (UX 우선)
          emptyEl.classList.add('hidden');
          if (requestDone) requestDone.classList.remove('hidden');

          // Supabase에 요청 저장
          try {
            if (supabaseUrl && supabaseKey) {
              await fetch(`${supabaseUrl}/rest/v1/article_requests`, {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                  'apikey': supabaseKey,
                  'Authorization': `Bearer ${supabaseKey}`,
                  'Prefer': 'return=minimal',
                },
                body: JSON.stringify({
                  query,
                  status: 'pending',
                  referrer: document.referrer || window.location.pathname,
                  user_agent: navigator.userAgent,
                }),
              });
            }
          } catch { /* 저장 실패해도 UI는 완료 상태 유지 */ }
        });
      }
    })();
		</script>
	</body>
</html>
