---
import AdminLayout from '../../../layouts/AdminLayout.astro';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const assetId = Astro.url.searchParams.get('id') ?? '';
---

<AdminLayout
  title="Media Detail"
  pageTitle="Media Detail"
  pageDescription="media asset의 metadata diff를 확인하고 수정, 아카이브, 복구를 실행합니다."
  status="Recovery"
  requiredRole="editor"
>
  <div class="admin-grid">
    <section class="admin-card pad-lg span-7">
      <div class="admin-actions-row">
        <div>
          <h2 class="admin-section-title">Asset Editor</h2>
          <p class="admin-section-desc">현재 자산의 metadata를 수정하고 아카이브/복구를 실행합니다.</p>
        </div>
        <div class="admin-actions-inline">
          <a class="admin-btn" href="/admin/media">Back</a>
          <button type="button" class="admin-btn" data-media-toggle-archive>아카이브/복구</button>
          <button type="submit" form="admin-media-detail-form" class="admin-btn primary">저장</button>
        </div>
      </div>

      <form id="admin-media-detail-form" class="admin-form-grid" data-media-detail-form>
        <div class="admin-field full">
          <label class="admin-label" for="file_name">파일명</label>
          <input id="file_name" name="file_name" class="admin-input" type="text" required />
        </div>

        <div class="admin-field full">
          <label class="admin-label" for="public_url">Public URL</label>
          <input id="public_url" name="public_url" class="admin-input" type="url" required />
        </div>

        <div class="admin-field">
          <label class="admin-label" for="storage_provider">Storage Provider</label>
          <input id="storage_provider" name="storage_provider" class="admin-input" type="text" />
        </div>

        <div class="admin-field">
          <label class="admin-label" for="storage_bucket">Bucket</label>
          <input id="storage_bucket" name="storage_bucket" class="admin-input" type="text" />
        </div>

        <div class="admin-field full">
          <label class="admin-label" for="file_path">File Path</label>
          <input id="file_path" name="file_path" class="admin-input" type="text" />
        </div>

        <div class="admin-field full">
          <label class="admin-label" for="alt_text">Alt Text</label>
          <input id="alt_text" name="alt_text" class="admin-input" type="text" />
        </div>

        <div class="admin-field full">
          <label class="admin-label" for="caption">Caption</label>
          <input id="caption" name="caption" class="admin-input" type="text" />
        </div>

        <div class="admin-field">
          <label class="admin-label" for="width">Width</label>
          <input id="width" name="width" class="admin-input" type="number" min="0" />
        </div>

        <div class="admin-field">
          <label class="admin-label" for="height">Height</label>
          <input id="height" name="height" class="admin-input" type="number" min="0" />
        </div>
      </form>

      <p class="admin-inline-note" data-media-detail-message hidden></p>
    </section>

    <div class="admin-panel-stack">
      <section class="admin-card pad-md">
        <h2 class="admin-section-title">Diff</h2>
        <p class="admin-section-desc">현재 값과 마지막 audit snapshot을 비교합니다.</p>
        <div class="admin-panel-stack" data-media-diff>
          <p class="admin-help">snapshot을 불러오는 중입니다.</p>
        </div>
      </section>

      <section class="admin-card pad-md">
        <h2 class="admin-section-title">History</h2>
        <p class="admin-section-desc">최근 변경과 복구 기록입니다.</p>
        <ul class="admin-list" data-media-history>
          <li class="admin-list-row"><div><p class="admin-item-title">불러오는 중...</p><p class="admin-item-meta">audit log를 조회합니다.</p></div></li>
        </ul>
      </section>
    </div>
  </div>

  <script type="module" define:vars={{ supabaseUrl, supabaseKey, assetId }}>
    import { createClient } from '@supabase/supabase-js';

    const form = document.querySelector('[data-media-detail-form]');
    const message = document.querySelector('[data-media-detail-message]');
    const diffList = document.querySelector('[data-media-diff]');
    const historyList = document.querySelector('[data-media-history]');
    const toggleArchiveButton = document.querySelector('[data-media-toggle-archive]');
    let currentAsset = null;
    let latestSnapshot = null;

    const setMessage = (text, state = 'info') => {
      if (!message) return;
      message.hidden = false;
      message.textContent = text;
      message.dataset.state = state;
    };

    const escapeHtml = (value) => String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');

    const formatValue = (value) => {
      if (value === null || value === undefined || value === '') return '-';
      if (typeof value === 'object') return JSON.stringify(value, null, 2);
      return String(value);
    };

    const applyAsset = (asset) => {
      if (!form || !asset) return;
      form.elements.file_name.value = asset.file_name || '';
      form.elements.public_url.value = asset.public_url || '';
      form.elements.storage_provider.value = asset.storage_provider || '';
      form.elements.storage_bucket.value = asset.storage_bucket || '';
      form.elements.file_path.value = asset.file_path || '';
      form.elements.alt_text.value = asset.alt_text || '';
      form.elements.caption.value = asset.caption || '';
      form.elements.width.value = asset.width || '';
      form.elements.height.value = asset.height || '';
      if (toggleArchiveButton) {
        toggleArchiveButton.textContent = asset.deleted_at ? '복구' : '아카이브';
      }
    };

    const renderDiff = (current, snapshot) => {
      if (!diffList) return;
      if (!current) {
        diffList.innerHTML = '<p class="admin-help">자산을 불러오는 중입니다.</p>';
        return;
      }

      const pairs = [
        ['file_name', current.file_name, snapshot?.file_name],
        ['public_url', current.public_url, snapshot?.public_url],
        ['storage_provider', current.storage_provider, snapshot?.storage_provider],
        ['storage_bucket', current.storage_bucket, snapshot?.storage_bucket],
        ['file_path', current.file_path, snapshot?.file_path],
        ['alt_text', current.alt_text, snapshot?.alt_text],
        ['caption', current.caption, snapshot?.caption],
        ['width', current.width, snapshot?.width],
        ['height', current.height, snapshot?.height],
        ['deleted_at', current.deleted_at, snapshot?.deleted_at],
      ];

      diffList.innerHTML = pairs.map(([label, currentValue, snapshotValue]) => {
        const changed = JSON.stringify(currentValue ?? null) !== JSON.stringify(snapshotValue ?? null);
        return `
          <article class="admin-detail-card ${changed ? 'admin-check-warn' : 'admin-check-ok'}">
            <div class="admin-check-card-head">
              <strong>${escapeHtml(label)}</strong>
              <span class="admin-status ${changed ? 'warn' : 'ready'}">${changed ? 'changed' : 'same'}</span>
            </div>
            <div class="admin-detail-grid">
              <div>
                <p class="admin-item-title">Current</p>
                <pre class="admin-code-block">${escapeHtml(formatValue(currentValue))}</pre>
              </div>
              <div>
                <p class="admin-item-title">Snapshot</p>
                <pre class="admin-code-block">${escapeHtml(formatValue(snapshotValue))}</pre>
              </div>
            </div>
          </article>
        `;
      }).join('');
    };

    const renderHistory = (rows) => {
      if (!historyList) return;
      if (!rows.length) {
        historyList.innerHTML = '<li class="admin-list-row"><div><p class="admin-item-title">이력이 없습니다.</p><p class="admin-item-meta">첫 변경 후 표시됩니다.</p></div></li>';
        return;
      }

      historyList.innerHTML = rows.map((row) => `
        <li class="admin-list-row">
          <div>
            <p class="admin-item-title">${escapeHtml(row.action)} · ${escapeHtml(row.created_at)}</p>
            <p class="admin-item-meta">${escapeHtml(row.after_json?.file_name || currentAsset?.file_name || '-')}</p>
          </div>
        </li>
      `).join('');
    };

    if (!supabaseUrl || !supabaseKey) {
      setMessage('Supabase 환경 변수가 없어 detail 페이지를 초기화할 수 없습니다.', 'error');
    } else {
      const supabase = createClient(supabaseUrl, supabaseKey, {
        auth: { persistSession: true, autoRefreshToken: true, detectSessionInUrl: true },
      });

      const { data: sessionData } = await supabase.auth.getSession();
      if (!sessionData.session) {
        window.location.replace('/admin/login?redirectTo=/admin/media/detail');
      } else if (!assetId) {
        setMessage('asset id가 필요합니다.', 'error');
      } else {
        const [{ data: assetData, error: assetError }, { data: logsData, error: logsError }] = await Promise.all([
          supabase.from('media_assets').select('id, file_name, storage_provider, storage_bucket, file_path, public_url, mime_type, alt_text, caption, width, height, deleted_at, created_at, updated_at').eq('id', assetId).maybeSingle(),
          supabase.from('audit_logs').select('id, action, created_at, actor_id, after_json').eq('resource_type', 'media_asset').eq('resource_id', assetId).order('created_at', { ascending: false }).limit(12),
        ]);

        if (assetError) {
          setMessage(assetError.message, 'error');
        } else if (!assetData) {
          setMessage('해당 asset을 찾을 수 없습니다.', 'error');
        } else {
          currentAsset = assetData;
          latestSnapshot = logsData?.[0]?.after_json || null;
          applyAsset(assetData);
          renderDiff(assetData, latestSnapshot);
          renderHistory(logsData || []);

          form?.addEventListener('submit', async (event) => {
            event.preventDefault();
            const formData = new FormData(form);
            const payload = {
              file_name: String(formData.get('file_name') || '').trim(),
              public_url: String(formData.get('public_url') || '').trim(),
              storage_provider: String(formData.get('storage_provider') || '').trim(),
              storage_bucket: String(formData.get('storage_bucket') || '').trim() || null,
              file_path: String(formData.get('file_path') || '').trim() || null,
              alt_text: String(formData.get('alt_text') || '').trim() || null,
              caption: String(formData.get('caption') || '').trim() || null,
              width: Number(formData.get('width') || 0) || null,
              height: Number(formData.get('height') || 0) || null,
            };

            const { data, error } = await supabase
              .from('media_assets')
              .update(payload)
              .eq('id', assetId)
              .select('id')
              .single();

            if (error) {
              setMessage(error.message, 'error');
              return;
            }

            await supabase.from('audit_logs').insert({
              actor_id: sessionData.session.user.id,
              action: 'media_asset_updated',
              resource_type: 'media_asset',
              resource_id: data.id,
              after_json: payload,
            });

            setMessage('media asset를 저장했습니다.', 'success');
            location.reload();
          });

          toggleArchiveButton?.addEventListener('click', async () => {
            const nextDeletedAt = currentAsset.deleted_at ? null : new Date().toISOString();
            const { error } = await supabase.from('media_assets').update({ deleted_at: nextDeletedAt }).eq('id', assetId);
            if (error) {
              setMessage(error.message, 'error');
              return;
            }

            await supabase.from('audit_logs').insert({
              actor_id: sessionData.session.user.id,
              action: nextDeletedAt ? 'media_asset_archived' : 'media_asset_restored',
              resource_type: 'media_asset',
              resource_id: assetId,
              after_json: { deleted_at: nextDeletedAt },
            });

            setMessage(nextDeletedAt ? '아카이브했습니다.' : '복구했습니다.', 'success');
            location.reload();
          });
        }
      }
    }
  </script>
</AdminLayout>
