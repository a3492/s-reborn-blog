---
import AdminLayout from '../../../layouts/AdminLayout.astro';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<AdminLayout
  title="Pipeline"
  pageTitle="Pipeline"
  pageDescription="publish pipeline нҷҳкІҪ ліҖмҲҳ, owner bootstrap, GitHub м—°кІ° мғҒнғңлҘј н•ң лІҲм—җ м җкІҖн•©лӢҲлӢӨ."
  status="Health Check"
>
  <div class="admin-grid">
    <section class="admin-card pad-lg span-7">
      <div class="admin-actions-row">
        <div>
          <h2 class="admin-section-title">Pipeline Health</h2>
          <p class="admin-section-desc">Cloudflare Pages Functions кё°мӨҖ м„ңлІ„ кІҖмҰқкіј нҳ„мһ¬ лЎңк·ёмқё кі„м •мқҳ bootstrap мғҒнғңлҘј н•Ёк»ҳ нҷ•мқён•©лӢҲлӢӨ.</p>
        </div>
        <button type="button" class="admin-btn primary" data-admin-pipeline-run>кІҖмҰқ мӢӨн–ү</button>
      </div>

      <p class="admin-inline-note" data-admin-pipeline-message hidden></p>

      <div class="admin-panel-stack" data-admin-pipeline-results>
        <p class="admin-help">кІҖмҰқ мӢӨн–ү м „мһ…лӢҲлӢӨ.</p>
      </div>
    </section>

    <section class="admin-card pad-lg span-5">
      <h2 class="admin-section-title">Bootstrap Checklist</h2>
      <p class="admin-section-desc">мҡҙмҳҒ м „ мөңмҶҢ нҷ•мқё н•ӯлӘ©мһ…лӢҲлӢӨ.</p>
      <ul class="admin-list" data-admin-bootstrap-checks>
        <li class="admin-list-row">
          <div>
            <p class="admin-item-title">м„ём…ҳ нҷ•мқё м „</p>
            <p class="admin-item-meta">нҳ„мһ¬ лЎңк·ёмқё кі„м •кіј admin_profilesлҘј нҷ•мқён•©лӢҲлӢӨ.</p>
          </div>
        </li>
      </ul>
    </section>

    <section class="admin-card pad-lg span-12">
      <h2 class="admin-section-title">Next Actions</h2>
      <p class="admin-section-desc">кІҖмҰқ кІ°кіјм—җ л”°лқј м•„лһҳ мҲңм„ңлЎң м§„н–үн•ҳл©ҙ лҗ©лӢҲлӢӨ.</p>
      <ul class="admin-list">
        <li class="admin-list-row"><div><p class="admin-item-title">1. owner bootstrap</p><p class="admin-item-meta">`admin_profiles`м—җ нҳ„мһ¬ лЎңк·ёмқё кі„м •мқ„ owner лҳҗлҠ” editorлЎң лЁјм Җ л“ұлЎқн•©лӢҲлӢӨ.</p></div></li>
        <li class="admin-list-row"><div><p class="admin-item-title">2. Pages env м—°кІ°</p><p class="admin-item-meta">`SUPABASE_URL`, `SUPABASE_SERVICE_ROLE_KEY`, `GITHUB_TOKEN`, `GITHUB_REPO`, `GITHUB_BRANCH`лҘј л°°нҸ¬ нҷҳкІҪм—җ л„ЈмҠөлӢҲлӢӨ.</p></div></li>
        <li class="admin-list-row"><div><p class="admin-item-title">3. dry run</p><p class="admin-item-meta">нҺём§‘ нҷ”л©ҙм—җм„ң `Publish Dry Run`мңјлЎң target pathмҷҖ frontmatter кө¬м„ұмқ„ лЁјм Җ нҷ•мқён•©лӢҲлӢӨ.</p></div></li>
        <li class="admin-list-row"><div><p class="admin-item-title">4. live publish</p><p class="admin-item-meta">`/admin/jobs`мҷҖ `/admin` лҢҖмӢңліҙл“ңм—җм„ң success/failed м „нҷҳмқ„ нҷ•мқён•©лӢҲлӢӨ.</p></div></li>
      </ul>
    </section>
  </div>

  <script type="module" define:vars={{ supabaseUrl, supabaseKey }}>
    import { createClient } from '@supabase/supabase-js';

    const message = document.querySelector('[data-admin-pipeline-message]');
    const results = document.querySelector('[data-admin-pipeline-results]');
    const bootstrap = document.querySelector('[data-admin-bootstrap-checks]');
    const runButton = document.querySelector('[data-admin-pipeline-run]');

    const setMessage = (text, state = 'info') => {
      if (!message) return;
      message.hidden = false;
      message.textContent = text;
      message.dataset.state = state;
    };

    const escapeHtml = (value) => String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');

    const renderBootstrapChecks = (items) => {
      if (!bootstrap) return;
      bootstrap.innerHTML = items.map((item) => `
        <li class="admin-list-row">
          <div>
            <p class="admin-item-title">${escapeHtml(item.label)}</p>
            <p class="admin-item-meta">${escapeHtml(item.detail)}</p>
          </div>
          <div><span class="admin-status ${escapeHtml(item.variant)}">${escapeHtml(item.variant)}</span></div>
        </li>
      `).join('');
    };

    const renderResults = (checks) => {
      if (!results) return;
      if (!checks?.length) {
        results.innerHTML = '<p class="admin-help">н‘ңмӢңн•  кІҖмҰқ кІ°кіјк°Җ м—ҶмҠөлӢҲлӢӨ.</p>';
        return;
      }

      results.innerHTML = checks.map((check) => `
        <article class="admin-check-card admin-check-${escapeHtml(check.status)}">
          <div class="admin-check-card-head">
            <h3 class="admin-section-title">${escapeHtml(check.label)}</h3>
            <span class="admin-status ${check.status === 'ok' ? 'success' : check.status === 'warn' ? 'warn' : 'failed'}">${escapeHtml(check.status)}</span>
          </div>
          <p class="admin-item-meta">${escapeHtml(check.detail)}</p>
        </article>
      `).join('');
    };

    if (!supabaseUrl || !supabaseKey) {
      setMessage('PUBLIC_SUPABASE_URL лҳҗлҠ” PUBLIC_SUPABASE_ANON_KEYк°Җ м—Ҷм–ҙ bootstrap кІҖмҰқмқ„ мӢңмһ‘н•  мҲҳ м—ҶмҠөлӢҲлӢӨ.', 'error');
      renderBootstrapChecks([
        { label: 'Public env', detail: 'PUBLIC_SUPABASE_URL / PUBLIC_SUPABASE_ANON_KEYлҘј лЁјм Җ м„Өм •н•ҙм•ј н•©лӢҲлӢӨ.', variant: 'failed' },
      ]);
    } else {
      const supabase = createClient(supabaseUrl, supabaseKey, {
        auth: { persistSession: true, autoRefreshToken: true, detectSessionInUrl: true },
      });

      const loadBootstrapState = async () => {
        const { data: sessionData } = await supabase.auth.getSession();
        const session = sessionData.session;

        if (!session) {
          window.location.replace('/admin/login?redirectTo=/admin/pipeline');
          return null;
        }

        const checks = [
          { label: 'нҳ„мһ¬ лЎңк·ёмқё кі„м •', detail: session.user.email || 'email м—ҶмқҢ', variant: 'success' },
        ];

        const { data: profile, error } = await supabase
          .from('admin_profiles')
          .select('email, role, display_name')
          .eq('id', session.user.id)
          .maybeSingle();

        if (error) {
          checks.push({ label: 'admin_profiles мЎ°нҡҢ', detail: error.message, variant: 'failed' });
        } else if (!profile) {
          checks.push({ label: 'owner bootstrap', detail: 'нҳ„мһ¬ кі„м •мқҙ admin_profilesм—җ м—ҶмҠөлӢҲлӢӨ. owner/editor л“ұлЎқмқҙ лЁјм Җ н•„мҡ”н•©лӢҲлӢӨ.', variant: 'warn' });
        } else {
          checks.push({ label: 'admin_profiles м—°кІ°', detail: `${profile.display_name || profile.email} В· ${profile.role}`, variant: 'success' });
        }

        renderBootstrapChecks(checks);
        return session;
      };

      const runHealthCheck = async () => {
        setMessage('pipeline кІҖмҰқмқ„ мӢӨн–үн•ҳлҠ” мӨ‘мһ…лӢҲлӢӨ...', 'info');
        renderResults([]);

        const response = await fetch('/api/admin/publish-health');
        let payload = null;
        try {
          payload = await response.json();
        } catch {
          payload = null;
        }

        if (!response.ok) {
          renderResults(payload?.checks || []);
          setMessage(payload?.checks?.some((check) => check.status === 'error') ? 'мӢӨнҢЁн•ң кІҖмҰқ н•ӯлӘ©мқҙ мһҲмҠөлӢҲлӢӨ.' : (payload?.error || 'pipeline кІҖмҰқм—җ мӢӨнҢЁн–ҲмҠөлӢҲлӢӨ.'), 'error');
          return;
        }

        renderResults(payload?.checks || []);
        setMessage(payload?.ok ? 'pipeline кІҖмҰқмқҙ лӘЁл‘җ нҶөкіјн–ҲмҠөлӢҲлӢӨ.' : 'кІҪкі  лҳҗлҠ” мӢӨнҢЁ н•ӯлӘ©мқҙ мһҲмҠөлӢҲлӢӨ.', payload?.ok ? 'success' : 'error');
      };

      await loadBootstrapState();
      runButton?.addEventListener('click', runHealthCheck);
    }
  </script>
</AdminLayout>
