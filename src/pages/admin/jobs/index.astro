---
import AdminLayout from '../../../layouts/AdminLayout.astro';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<AdminLayout
  title="Jobs"
  pageTitle="Jobs"
  pageDescription="publish_jobs와 최근 배포 요청 이력을 확인합니다."
  status="Publish Jobs"
>
  <div class="admin-card pad-lg">
    <div class="admin-actions-row">
      <div>
        <h2 class="admin-section-title">Publish Jobs</h2>
        <p class="admin-section-desc">최근 발행 요청 상태와 실패 사유를 시간순으로 조회합니다.</p>
      </div>
      <div class="admin-actions-cluster">
        <span class="admin-live-badge" data-admin-jobs-live>Auto refresh</span>
        <a href="/admin/posts" class="admin-btn">Posts로 이동</a>
      </div>
    </div>

    <p class="admin-inline-note" data-admin-jobs-message hidden></p>

    <div class="admin-jobs-toolbar">
      <p class="admin-help">실행 중인 job이 있으면 8초마다 자동 갱신합니다.</p>
      <button type="button" class="admin-btn" data-admin-jobs-refresh>지금 새로고침</button>
    </div>

    <table class="admin-table">
      <thead>
        <tr>
          <th>Status</th>
          <th>Path</th>
          <th>Repo / Branch</th>
          <th>Commit / Error</th>
          <th>Created</th>
        </tr>
      </thead>
      <tbody data-admin-jobs-body>
        <tr><td colspan="5">불러오는 중...</td></tr>
      </tbody>
    </table>
  </div>

  <script type="module" define:vars={{ supabaseUrl, supabaseKey }}>
    import { createClient } from '@supabase/supabase-js';

    const body = document.querySelector('[data-admin-jobs-body]');
    const message = document.querySelector('[data-admin-jobs-message]');
    const refreshButton = document.querySelector('[data-admin-jobs-refresh]');
    const liveBadge = document.querySelector('[data-admin-jobs-live]');
    let refreshTimer = null;

    const setMessage = (text, state = 'info') => {
      if (!message) return;
      message.hidden = false;
      message.textContent = text;
      message.dataset.state = state;
    };

    const formatDate = (value) => {
      if (!value) return '-';
      return new Intl.DateTimeFormat('ko-KR', {
        year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit'
      }).format(new Date(value));
    };

    const escapeHtml = (value) => String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');

    const renderRows = (rows) => {
      if (!body) return;
      if (!rows.length) {
        body.innerHTML = '<tr><td colspan="5">아직 publish job이 없습니다.</td></tr>';
        return false;
      }

      body.innerHTML = rows.map((row) => {
        const isDone = row.status === 'success' || row.status === 'failed';
        const commitOrError = row.status === 'failed'
          ? `<span class="admin-cell-error">${escapeHtml(row.error_message ?? 'unknown error')}</span>`
          : `<span class="admin-cell-mono">${escapeHtml(row.commit_sha ?? '-')}</span>`;
        const liveState = isDone ? '' : '<span class="admin-pulse-dot"></span>';

        return `
          <tr>
            <td><span class="admin-status ${escapeHtml(row.status)}">${liveState}${escapeHtml(row.status)}</span></td>
            <td>${escapeHtml(row.target_path ?? '-')}</td>
            <td>${escapeHtml(row.target_repo ?? '-')}<br /><span class="admin-cell-subtle">${escapeHtml(row.target_branch ?? '-')}</span></td>
            <td>${commitOrError}</td>
            <td>${formatDate(row.created_at)}</td>
          </tr>
        `;
      }).join('');

      return rows.some((row) => row.status === 'pending' || row.status === 'processing');
    };

    const toggleAutoRefresh = (active) => {
      if (!liveBadge) return;
      liveBadge.dataset.active = active ? 'true' : 'false';
      liveBadge.textContent = active ? 'Live polling' : 'Auto refresh';
    };

    if (!supabaseUrl || !supabaseKey) {
      renderRows([]);
      setMessage('Supabase 환경 변수가 없어 publish job을 불러올 수 없습니다.', 'error');
    } else {
      const supabase = createClient(supabaseUrl, supabaseKey, {
        auth: { persistSession: true, autoRefreshToken: true, detectSessionInUrl: true },
      });

      const loadJobs = async (silent = false) => {
        const { data, error } = await supabase
          .from('publish_jobs')
          .select('status, target_path, target_repo, target_branch, commit_sha, error_message, created_at')
          .order('created_at', { ascending: false })
          .limit(20);

        if (error) {
          renderRows([]);
          setMessage(error.message, 'error');
          toggleAutoRefresh(false);
          return;
        }

        const hasRunning = renderRows(data ?? []);
        toggleAutoRefresh(hasRunning);

        if (!silent) {
          setMessage(`최근 ${String((data ?? []).length)}개의 publish job을 불러왔습니다.`, 'info');
        }
      };

      const scheduleRefresh = () => {
        if (refreshTimer) window.clearInterval(refreshTimer);
        refreshTimer = window.setInterval(() => {
          if (document.hidden) return;
          loadJobs(true);
        }, 8000);
      };

      const { data: sessionData } = await supabase.auth.getSession();
      if (!sessionData.session) {
        window.location.replace('/admin/login?redirectTo=/admin/jobs');
      } else {
        await loadJobs();
        scheduleRefresh();
        refreshButton?.addEventListener('click', () => loadJobs());
        document.addEventListener('visibilitychange', () => {
          if (!document.hidden) loadJobs(true);
        });
      }
    }
  </script>
</AdminLayout>
