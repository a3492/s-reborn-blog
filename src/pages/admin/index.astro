---
import AdminLayout from '../../layouts/AdminLayout.astro';

const recentDrafts = [
  { title: 'AI와 의료 워크플로우 메모', meta: 'draft · 마지막 수정 2시간 전' },
  { title: '블로그 운영 메타 정리', meta: 'draft · 마지막 수정 어제' },
];

const nextSteps = [
  { title: '관리자 인증 연결', meta: 'Supabase Auth + role gating' },
  { title: '글 저장 API 연결', meta: 'draft 저장과 revision 테이블 연결' },
  { title: 'Preview route 추가', meta: 'Markdown 미리보기 렌더링' },
];
---

<AdminLayout
  title="Dashboard"
  pageTitle="Dashboard"
  pageDescription="Phase 1의 기준 화면입니다. 인증, 글 목록, 새 글 작성 흐름을 먼저 연결하는 것을 목표로 합니다."
  status="Phase 1"
>
  <div class="admin-grid">
    <section class="admin-card pad-lg span-4">
      <h2 class="admin-section-title">Draft Posts</h2>
      <p class="admin-section-desc">임시 저장된 글 수</p>
      <div class="admin-kpi">
        <strong class="admin-kpi-value">2</strong>
        <span class="admin-kpi-label">초기 더미 데이터</span>
      </div>
    </section>

    <section class="admin-card pad-lg span-4">
      <h2 class="admin-section-title">Publish Jobs</h2>
      <p class="admin-section-desc">Phase 3에서 GitHub 발행 파이프라인과 연결</p>
      <div class="admin-kpi">
        <strong class="admin-kpi-value">0</strong>
        <span class="admin-kpi-label">아직 구현 전</span>
      </div>
    </section>

    <section class="admin-card pad-lg span-4">
      <h2 class="admin-section-title">Schema State</h2>
      <p class="admin-section-desc">DB migration 초안 준비 상태</p>
      <div class="admin-kpi">
        <strong class="admin-kpi-value">Ready</strong>
        <span class="admin-kpi-label">`supabase/migrations` 초안 추가됨</span>
      </div>
    </section>

    <section class="admin-card pad-lg span-7">
      <h2 class="admin-section-title">Recent Drafts</h2>
      <p class="admin-section-desc">실제 연결 전까지는 예시 행으로 구성했습니다.</p>
      <ul class="admin-list">
        {recentDrafts.map((item) => (
          <li class="admin-list-row">
            <div>
              <p class="admin-item-title">{item.title}</p>
              <p class="admin-item-meta">{item.meta}</p>
            </div>
            <div>
              <span class="admin-status draft">Draft</span>
            </div>
          </li>
        ))}
      </ul>
    </section>

    <section class="admin-card pad-lg span-5">
      <h2 class="admin-section-title">Immediate Next Steps</h2>
      <p class="admin-section-desc">Phase 1 구현 순서입니다.</p>
      <ul class="admin-list">
        {nextSteps.map((item) => (
          <li class="admin-list-row">
            <div>
              <p class="admin-item-title">{item.title}</p>
              <p class="admin-item-meta">{item.meta}</p>
            </div>
            <div>
              <span class="admin-status warn">Todo</span>
            </div>
          </li>
        ))}
      </ul>
    </section>
  </div>
</AdminLayout>
