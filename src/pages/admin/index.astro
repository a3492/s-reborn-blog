---
import AdminLayout from '../../layouts/AdminLayout.astro';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<AdminLayout
  title="Dashboard"
  pageTitle="Dashboard"
  pageDescription="Phase 1의 기준 화면입니다. 인증, 글 목록, 새 글 작성 흐름을 먼저 연결하는 것을 목표로 합니다."
  status="Phase 1"
>
  <div class="admin-grid">
    <section class="admin-card pad-lg span-4">
      <h2 class="admin-section-title">Draft Posts</h2>
      <p class="admin-section-desc">임시 저장된 글 수</p>
      <div class="admin-kpi">
        <strong class="admin-kpi-value" data-admin-kpi-drafts>-</strong>
        <span class="admin-kpi-label">Supabase 연결 후 실시간 집계</span>
      </div>
    </section>

    <section class="admin-card pad-lg span-4">
      <h2 class="admin-section-title">Recent Activity</h2>
      <p class="admin-section-desc">최근 생성/수정 로그 수</p>
      <div class="admin-kpi">
        <strong class="admin-kpi-value" data-admin-kpi-logs>-</strong>
        <span class="admin-kpi-label">audit_logs 기준</span>
      </div>
    </section>

    <section class="admin-card pad-lg span-4">
      <h2 class="admin-section-title">Schema State</h2>
      <p class="admin-section-desc">DB migration 초안 준비 상태</p>
      <div class="admin-kpi">
        <strong class="admin-kpi-value">Ready</strong>
        <span class="admin-kpi-label">`supabase/migrations` 초안 추가됨</span>
      </div>
    </section>

    <section class="admin-card pad-lg span-7">
      <h2 class="admin-section-title">Recent Drafts</h2>
      <p class="admin-section-desc">최근 저장된 글을 실시간으로 보여줍니다.</p>
      <p class="admin-inline-note" data-admin-dashboard-message hidden></p>
      <ul class="admin-list" data-admin-dashboard-drafts>
        <li class="admin-list-row">
          <div>
            <p class="admin-item-title">불러오는 중...</p>
            <p class="admin-item-meta">Supabase에서 최근 글을 가져옵니다.</p>
          </div>
        </li>
      </ul>
    </section>

    <section class="admin-card pad-lg span-5">
      <h2 class="admin-section-title">Recent Activity Feed</h2>
      <p class="admin-section-desc">최근 audit log 5개를 표시합니다.</p>
      <ul class="admin-list" data-admin-dashboard-logs>
        <li class="admin-list-row">
          <div>
            <p class="admin-item-title">불러오는 중...</p>
            <p class="admin-item-meta">최근 작업 로그를 가져옵니다.</p>
          </div>
        </li>
      </ul>
    </section>
  </div>

  <script type="module" define:vars={{ supabaseUrl, supabaseKey }}>
    import { createClient } from '@supabase/supabase-js';

    const draftsKpi = document.querySelector('[data-admin-kpi-drafts]');
    const logsKpi = document.querySelector('[data-admin-kpi-logs]');
    const draftList = document.querySelector('[data-admin-dashboard-drafts]');
    const logList = document.querySelector('[data-admin-dashboard-logs]');
    const message = document.querySelector('[data-admin-dashboard-message]');

    const setMessage = (text, state = 'info') => {
      if (!message) return;
      message.hidden = false;
      message.textContent = text;
      message.dataset.state = state;
    };

    const formatDate = (value) => {
      if (!value) return '-';
      return new Intl.DateTimeFormat('ko-KR', {
        year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit'
      }).format(new Date(value));
    };

    const escapeHtml = (value) => String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');

    const renderDrafts = (rows) => {
      if (!draftList) return;
      if (!rows.length) {
        draftList.innerHTML = '<li class="admin-list-row"><div><p class="admin-item-title">저장된 draft가 없습니다.</p><p class="admin-item-meta">/admin/posts/new 에서 첫 글을 만들어 보세요.</p></div></li>';
        return;
      }
      draftList.innerHTML = rows.map((row) => `
        <li class="admin-list-row">
          <div>
            <p class="admin-item-title"><a class="admin-table-link" href="/admin/posts/edit?slug=${encodeURIComponent(row.slug)}">${escapeHtml(row.title)}</a></p>
            <p class="admin-item-meta">${escapeHtml(row.slug)} · ${formatDate(row.updated_at)}</p>
          </div>
          <div><span class="admin-status ${escapeHtml(row.status)}">${escapeHtml(row.status)}</span></div>
        </li>
      `).join('');
    };

    const renderLogs = (rows) => {
      if (!logList) return;
      if (!rows.length) {
        logList.innerHTML = '<li class="admin-list-row"><div><p class="admin-item-title">로그가 없습니다.</p><p class="admin-item-meta">글 생성/수정 후 기록됩니다.</p></div></li>';
        return;
      }
      logList.innerHTML = rows.map((row) => `
        <li class="admin-list-row">
          <div>
            <p class="admin-item-title">${escapeHtml(row.action)}</p>
            <p class="admin-item-meta">${escapeHtml(row.resource_type)} · ${formatDate(row.created_at)}</p>
          </div>
        </li>
      `).join('');
    };

    if (!supabaseUrl || !supabaseKey) {
      if (draftsKpi) draftsKpi.textContent = '-';
      if (logsKpi) logsKpi.textContent = '-';
      renderDrafts([]);
      renderLogs([]);
      setMessage('Supabase 환경 변수가 없어 대시보드를 불러올 수 없습니다.', 'error');
    } else {
      const supabase = createClient(supabaseUrl, supabaseKey, {
        auth: { persistSession: true, autoRefreshToken: true, detectSessionInUrl: true },
      });

      const { data: sessionData } = await supabase.auth.getSession();
      if (!sessionData.session) {
        window.location.replace('/admin/login?redirectTo=/admin');
      } else {
        const [{ data: posts, error: postsError }, { data: logs, error: logsError }] = await Promise.all([
          supabase.from('posts').select('title, slug, status, updated_at').order('updated_at', { ascending: false }).limit(5),
          supabase.from('audit_logs').select('action, resource_type, created_at').order('created_at', { ascending: false }).limit(5),
        ]);

        if (postsError) {
          if (draftsKpi) draftsKpi.textContent = '-';
          renderDrafts([]);
          setMessage(postsError.message, 'error');
        } else {
          const rows = posts ?? [];
          if (draftsKpi) draftsKpi.textContent = String(rows.filter((row) => row.status === 'draft').length);
          renderDrafts(rows);
        }

        if (logsError) {
          if (logsKpi) logsKpi.textContent = '-';
          renderLogs([]);
        } else {
          if (logsKpi) logsKpi.textContent = String((logs ?? []).length);
          renderLogs(logs ?? []);
        }
      }
    }
  </script>
</AdminLayout>
