---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { CATEGORIES, MENU_GROUPS } from '../consts';
import { getPublicSiteSettings } from '../lib/site-settings';

const siteSettings = await getPublicSiteSettings();
const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const countsByCategory = allPosts.reduce<Record<string, number>>((acc, post) => {
	const c = post.data.category;
	if (c) acc[c] = (acc[c] ?? 0) + 1;
	return acc;
}, {});

const splitTitle = (title: string) => {
	const [main, ...rest] = title.split(' — ');
	return { main, sub: rest.length ? '— ' + rest.join(' — ') : null };
};

const stripMarkdown = (md: string) =>
	md
		.replace(/\r\n/g, '\n')
		.replace(/<!--[\s\S]*?-->/g, '')
		.replace(/^\s*\|.*\|\s*$/gm, '')
		.replace(/^#{1,6}\s+.*$/gm, '')
		.replace(/\*\*(.+?)\*\*/g, '$1')
		.replace(/\*(.+?)\*/g, '$1')
		.replace(/\[\[([^\]|]+)\|([^\]]+)\]\]/g, '$2')
		.replace(/\[\[([^\]]+)\]\]/g, '$1')
		.replace(/\[(.+?)\]\(.+?\)/g, '$1')
		.replace(/`+[^`]*`+/g, '')
		.replace(/^\s*[-*+]\s+/gm, '')
		.replace(/\n{3,}/g, '\n\n')
		.trim();

// SSR 기본값 — JS 로드 전 초기 렌더링용
const defaultPost = allPosts[0];
const { main: defaultMain, sub: defaultSub } = defaultPost
	? splitTitle(defaultPost.data.title)
	: { main: '', sub: null };
const defaultBodyRaw = stripMarkdown(defaultPost?.body ?? '').slice(0, 200);
const defaultParagraphs = defaultBodyRaw.split('\n\n').map(p => p.trim()).filter(Boolean);

// 클라이언트 랜덤화를 위한 전체 포스트 데이터
const postsData = allPosts.map((p) => {
	const { main, sub } = splitTitle(p.data.title);
	return {
		href: `/blog/${p.id}/`,
		titleMain: main,
		titleSub: sub ?? null,
		bodyPreview: stripMarkdown(p.body ?? '').slice(0, 200),
		category: p.data.category ?? '',
	};
});

// 애린이 코너 데이터
const aeriniPosts = allPosts.filter(p => p.data.category === 'aerini');
const aeriniData = aeriniPosts.map(p => {
	const slug = p.id.split('/').pop() ?? '';
	const badge = slug.startsWith('what-is') ? '개념 설명'
		: (slug.startsWith('faq-') || slug.startsWith('is-') || slug.startsWith('will-') || slug.startsWith('which-') || slug.startsWith('should-')) ? 'FAQ'
		: '실전팁';
	return {
		href: `/blog/${p.id}/`,
		title: p.data.title,
		description: p.data.description ?? '',
		badge,
	};
});
---

<Layout>
	{allPosts.length > 0 ? (
		<div class="blog-layout">

			<!-- ── 좌측 네비게이션 (블로그와 동일) ── -->
			<nav class="blog-nav" id="blog-nav" aria-label="카테고리 내비게이션">

				<!-- 모바일 토글 -->
				<button class="blog-nav-mobile-toggle" id="blog-nav-toggle" aria-expanded="false">
					<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
						<path d="M2 4h12M2 8h12M2 12h12"/>
					</svg>
					<span>카테고리</span>
					<svg class="blog-nav-mobile-chevron" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M3 1.5l4 3.5-4 3.5"/></svg>
				</button>

				<div class="blog-nav-body" id="blog-nav-body">
					<!-- 전체 -->
					<a class="blog-nav-all" href="/blog/" data-navlink>
						<span class="blog-nav-all-label">⊞ 전체 글</span>
						<span class="blog-nav-count">{allPosts.length}</span>
					</a>

					<div class="blog-nav-divider"></div>

					<!-- 그룹 -->
					{MENU_GROUPS.map((group) => (
						<div class="blog-nav-group" data-group={group.id}>
							<button class="blog-nav-group-hd" data-toggle={group.id}>
								<span class="blog-nav-group-icon">{group.icon}</span>
								<span class="blog-nav-group-label">{group.label}</span>
								<svg class="blog-nav-chevron" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
									<path d="M3 1.5l4 3.5-4 3.5"/>
								</svg>
							</button>
							<div class="blog-nav-group-body">
								{group.cats.map((catId) => {
									const cat = CATEGORIES.find((c) => c.id === catId);
									if (!cat) return null;
									const count = countsByCategory[catId] ?? 0;
									return (
										<a
											class="blog-nav-item"
											href={`/blog/?category=${catId}`}
											data-navlink
										>
											<span class="blog-nav-item-label">{cat.label}</span>
											<span class="blog-nav-item-count">{count}</span>
										</a>
									);
								})}
							</div>
						</div>
					))}
				</div>
			</nav>

			<!-- ── 홈 콘텐츠 영역 ── -->
			<main class="blog-content home-content">

				<!-- 히어로 랜덤 글 카드 -->
				<a class="yt-hero" id="yt-hero" href={`/blog/${defaultPost?.id}/`}>
					<h1 class="yt-title" id="yt-hero-title">
						{defaultMain}
						{defaultSub && <><br /><span class="yt-title-sub">{defaultSub}</span></>}
					</h1>
					<div class="yt-body-wrap" id="yt-body-wrap">
						<div id="yt-hero-body">
							{defaultParagraphs.map(p => <p class="yt-body-preview">{p}</p>)}
						</div>
					</div>
					<button class="yt-body-toggle" id="yt-body-toggle" aria-label="본문 펼치기">︾︾</button>
				</a>

				<!-- 애린이 코너 섹션 -->
				<div class="sec-rule" style="margin-top: 1.5rem;">
					<div class="sec-copy">
						<span class="sec-label">🌱 애린이 코너</span>
					</div>
					<div class="sec-line"></div>
					<a href="/blog/?category=aerini" class="sec-all">→</a>
				</div>
				<div class="aerini-wrap">
					<div class="aerini-frame" id="aerini-frame">
						{aeriniData.slice(0, 5).map(p => (
							<a class="aerini-card" href={p.href}>
								<span class="aerini-card-badge">{p.badge}</span>
								<p class="aerini-card-title">{p.title}</p>
								<p class="aerini-card-desc">{p.description}</p>
							</a>
						))}
						<a class="aerini-more" href="/blog/?category=aerini">전체 {aeriniPosts.length}개 보기 →</a>
					</div>
				</div>

				<!-- S-Reborn Lab (하단 허브) -->
				<div class="sec-rule" style="margin-top: 2rem;">
					<div class="sec-copy">
						<span class="sec-label">S-Reborn Lab</span>
					</div>
					<div class="sec-line"></div>
					<a href="/lab/" class="sec-all">→</a>
				</div>
				<div class="lab-teaser-wrap">
					<a class="lab-teaser" href="/lab/">
						<span class="lab-teaser-eyebrow">실험실 · 허브</span>
						<h2 class="lab-teaser-title">Doctor AI Academy · S-Reborn Clinic Blog</h2>
						<p class="lab-teaser-desc">임상의 AI 교육 시리즈는 Lab에서 열 수 있습니다. S-Reborn Clinic Blog는 준비중입니다.</p>
						<span class="lab-teaser-cta">Lab 열기 →</span>
					</a>
				</div>
			</main>
		</div>
	) : (
		<div style="padding: 4rem 2rem; color: var(--t2); text-align: center;">
			아직 작성된 글이 없습니다.
		</div>
	)}

	<!-- 포스트 데이터 JSON embed -->
	<script type="application/json" id="yt-posts-data" set:html={JSON.stringify(postsData)}></script>
	<script type="application/json" id="aerini-posts-data" set:html={JSON.stringify(aeriniData)}></script>

	<script is:inline>
		(function () {
			function escapeHtml(str) {
				return String(str)
					.replace(/&/g, '&amp;')
					.replace(/</g, '&lt;')
					.replace(/>/g, '&gt;')
					.replace(/"/g, '&quot;');
			}

			// 히어로 랜덤 선정
			var dataEl = document.getElementById('yt-posts-data');
			if (dataEl) {
				var posts = JSON.parse(dataEl.textContent || '[]');
				if (posts.length) {
					var heroIdx = Math.floor(Math.random() * posts.length);
					var hero = posts[heroIdx];

					var heroEl = document.getElementById('yt-hero');
					if (heroEl) heroEl.href = hero.href;

					var titleEl = document.getElementById('yt-hero-title');
					if (titleEl) {
						titleEl.innerHTML = escapeHtml(hero.titleMain) +
							(hero.titleSub ? '<br><span class="yt-title-sub">' + escapeHtml(hero.titleSub) + '</span>' : '');
					}

					var bodyEl = document.getElementById('yt-hero-body');
					if (bodyEl) {
						var paragraphs = hero.bodyPreview.split('\n\n').map(function(p) { return p.trim(); }).filter(Boolean);
						bodyEl.innerHTML = paragraphs.map(function(p) {
							return '<p class="yt-body-preview">' + escapeHtml(p) + '</p>';
						}).join('');
					}
				}
			}

			// 펼치기/접기 토글
			var toggle = document.getElementById('yt-body-toggle');
			var wrap = document.getElementById('yt-body-wrap');
			if (toggle && wrap) {
				toggle.addEventListener('click', function (e) {
					e.preventDefault();
					e.stopPropagation();
					var expanded = wrap.classList.toggle('expanded');
					toggle.textContent = expanded ? '︽︽' : '︾︾';
					toggle.setAttribute('aria-label', expanded ? '본문 접기' : '본문 펼치기');
				});
			}

			// 애린이 카드 랜덤화
			var aeriniEl = document.getElementById('aerini-posts-data');
			var aeriniFrame = document.getElementById('aerini-frame');
			if (aeriniEl && aeriniFrame) {
				var aeriniPosts = JSON.parse(aeriniEl.textContent || '[]');
				aeriniPosts.sort(function () { return Math.random() - 0.5; });
				var shown = aeriniPosts.slice(0, 5);
				var totalCount = aeriniPosts.length;
				aeriniFrame.innerHTML = shown.map(function (p) {
					return '<a class="aerini-card" href="' + escapeHtml(p.href) + '">' +
						'<span class="aerini-card-badge">' + escapeHtml(p.badge) + '</span>' +
						'<p class="aerini-card-title">' + escapeHtml(p.title) + '</p>' +
						'<p class="aerini-card-desc">' + escapeHtml(p.description) + '</p>' +
						'</a>';
				}).join('') +
				'<a class="aerini-more" href="/blog/?category=aerini">전체 ' + totalCount + '개 보기 →</a>';
			}

			// 그룹 펼치기/접기
			document.querySelectorAll('.blog-nav-group-hd').forEach(function(hd) {
				hd.addEventListener('click', function() {
					hd.closest('.blog-nav-group').classList.toggle('is-open');
				});
			});

			// 모바일 토글
			var mobileToggle = document.getElementById('blog-nav-toggle');
			var navBody = document.getElementById('blog-nav-body');
			if (mobileToggle && navBody) {
				mobileToggle.addEventListener('click', function() {
					var open = navBody.classList.toggle('is-open');
					mobileToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
				});
			}
		})();
	</script>
</Layout>
