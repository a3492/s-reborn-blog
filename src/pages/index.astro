---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getPublicSiteSettings } from '../lib/site-settings';

const siteSettings = await getPublicSiteSettings();
const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const configuredFeatured = siteSettings.featuredSlug
	? allPosts.find((post) => post.slug === siteSettings.featuredSlug || post.id.endsWith(`/${siteSettings.featuredSlug}`) || post.id === siteSettings.featuredSlug)
	: null;
const featuredPost = configuredFeatured || allPosts[0];
const sidebarPosts = featuredPost
	? allPosts.filter((post) => post.id !== featuredPost.id)
	: allPosts.slice(1);

const totalPosts = allPosts.length;
const totalCategories = new Set(allPosts.map((post) => post.data.category).filter(Boolean)).size;
const latestUpdate = allPosts[0]?.data.date;

const splitTitle = (title: string) => {
	const [main, ...rest] = title.split(' — ');
	return { main, sub: rest.length ? '— ' + rest.join(' — ') : null };
};
---

<Layout>
	{featuredPost ? (
		<div class="yt-layout">
			<!-- 좌측: 메인 피처드 카드 -->
			<main class="yt-main">
				{(() => {
					const { main, sub } = splitTitle(featuredPost.data.title);
					return (
						<a class="yt-hero" href={`/blog/${featuredPost.id}/`}>
							<div class="yt-kicker">
								<span class="yt-tag">{featuredPost.data.category ?? 'featured'}</span>
								<span class="yt-label">Latest Note</span>
							</div>
							<h1 class="yt-title">
								{main}
								{sub && <><br /><span class="yt-title-sub">{sub}</span></>}
							</h1>
							<p class="yt-desc">{featuredPost.data.description}</p>
							<div class="yt-foot">
								<time class="yt-date"><FormattedDate date={featuredPost.data.date} /></time>
								<span class="yt-arrow">→</span>
							</div>
						</a>
					);
				})()}

				<div class="yt-stats">
					<span>글 {totalPosts}</span>
					<span class="yt-stats-dot">·</span>
					<span>카테고리 {totalCategories}</span>
					<span class="yt-stats-dot">·</span>
					<FormattedDate date={latestUpdate} />
				</div>
			</main>

			<!-- 우측: 스크롤 가능한 사이드바 -->
			<aside class="yt-sidebar" id="yt-sidebar">
				{sidebarPosts.map((post) => {
					const { main, sub } = splitTitle(post.data.title);
					return (
						<a class="yt-item" href={`/blog/${post.id}/`} data-yt-post>
							{post.data.category && <span class="yt-item-cat">{post.data.category}</span>}
							<p class="yt-item-title">
								{main}
								{sub && <> <span style="color:var(--t3);font-weight:400">{sub}</span></>}
							</p>
							<div class="yt-item-foot">
								<time class="yt-item-date"><FormattedDate date={post.data.date} /></time>
								<span class="yt-item-arrow">→</span>
							</div>
						</a>
					);
				})}
			</aside>
		</div>
	) : (
		<div style="padding: 4rem 2rem; color: var(--t2); text-align: center;">
			아직 작성된 글이 없습니다.
		</div>
	)}

	<!-- Doctor AI 시리즈 섹션 -->
	<div class="sec-rule" style="margin-top: 2.5rem;">
		<div class="sec-copy">
			<span class="sec-label">Doctor AI Series</span>
			<p class="sec-desc">임상 현장에서 AI를 안전하게 이해하고 활용하기 위한 의사를 위한 실무 교육</p>
		</div>
		<div class="sec-line"></div>
		<a href="/doctor-ai/" class="sec-all">→</a>
	</div>

	<div class="dai-wrap">
		<a class="dai-hero" href="/doctor-ai/">
			<div class="dai-hero-text">
				<span class="dai-eyebrow">Fundamentals · 5편 완성</span>
				<h2 class="dai-title">의사가 배우는 AI</h2>
				<p class="dai-desc">AI의 작동 원리부터 외래 진료 워크플로우 적용, 안전한 프롬프팅까지 — 임상의를 위한 첫 번째 AI 교육 시리즈</p>
				<span class="dai-cta">→</span>
			</div>
			<div class="dai-hero-articles">
				<div class="dai-article-list">
					<span class="dai-item">01 · AI의 강점과 한계</span>
					<span class="dai-item">02 · 외래 진료 워크플로우</span>
					<span class="dai-item">03 · 안전한 의료 프롬프팅</span>
					<span class="dai-item">04 · 레지던트 교육과 연구</span>
					<span class="dai-item dai-item--more">+ 더 보기</span>
				</div>
			</div>
		</a>
	</div>

	<script>
		// 사이드바 글 목록 무작위 섞기 (매 방문마다 다른 순서)
		const sidebar = document.getElementById('yt-sidebar');
		if (sidebar) {
			const items = [...sidebar.querySelectorAll('[data-yt-post]')];
			items.sort(() => Math.random() - 0.5);
			items.forEach((el) => sidebar.appendChild(el));
		}
	</script>
</Layout>
