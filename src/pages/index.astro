---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getPublicSiteSettings } from '../lib/site-settings';

const siteSettings = await getPublicSiteSettings();
const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const configuredFeatured = siteSettings.featuredSlug
	? allPosts.find((post) => post.slug === siteSettings.featuredSlug || post.id.endsWith(`/${siteSettings.featuredSlug}`) || post.id === siteSettings.featuredSlug)
	: null;
const featuredPost = configuredFeatured || allPosts[0];
const rankedPosts = featuredPost
	? [featuredPost, ...allPosts.filter((post) => post.id !== featuredPost.id)]
	: allPosts;
const visiblePosts = rankedPosts.slice(0, 8);
const sidePosts = visiblePosts.slice(1, 3);
const gridPosts = visiblePosts.slice(3);
const totalPosts = allPosts.length;
const totalCategories = new Set(allPosts.map((post) => post.data.category).filter(Boolean)).size;
const latestUpdate = allPosts[0]?.data.date;
---

<Layout>
	{featuredPost ? (
		<div class="featured-wrap">
			<a class="featured-main" href={`/blog/${featuredPost.id}/`}>
				<div class="f-kicker">
					<span class="f-tag">{featuredPost.data.category ?? 'FEATURED'}</span>
					<span class="f-label">Latest Note</span>
				</div>
				<h1 class="f-title">{featuredPost.data.title}</h1>
				<p class="f-excerpt">{featuredPost.data.description}</p>
				<div class="f-foot">
					<div class="f-meta">
						<span class="f-meta-label">가장 최근에 발행한 글</span>
						<time class="f-date"><FormattedDate date={featuredPost.data.date} /></time>
					</div>
					<span class="read-link">읽기 →</span>
				</div>
			</a>
			<aside class="featured-side">
				<div class="side-head">
					<span class="side-head-label">더 읽어보기</span>
					<a href="/blog" class="side-head-link">아카이브</a>
				</div>
				{sidePosts.map((post) => (
					<a href={`/blog/${post.id}/`} class="side-post">
						{post.data.category && <span class="side-cat">{post.data.category}</span>}
						<h2 class="side-title">{post.data.title}</h2>
						<p class="side-exc">{post.data.description}</p>
						<span class="side-date"><FormattedDate date={post.data.date} /></span>
					</a>
				))}
			</aside>
		</div>

		<div class="home-signal">
			<div class="home-signal-card">
				<span class="home-signal-label">Archive</span>
				<strong>{totalPosts} posts</strong>
				<p>의학과 AI 기록을 최근 순서대로 묶어 보여줍니다.</p>
			</div>
			<div class="home-signal-card">
				<span class="home-signal-label">Coverage</span>
				<strong>{totalCategories} topics</strong>
				<p>카테고리별로 글의 결을 빠르게 훑을 수 있습니다.</p>
			</div>
			<div class="home-signal-card">
				<span class="home-signal-label">Latest</span>
				<strong><FormattedDate date={latestUpdate} /></strong>
				<p>가장 최근에 손본 글의 날짜를 바로 확인합니다.</p>
			</div>
		</div>
	) : (
		<div style="padding: 4rem 2rem; color: var(--t2); text-align: center;">
			아직 작성된 글이 없습니다.
		</div>
	)}

	<div class="sec-rule">
		<div class="sec-copy">
			<span class="sec-label">Recent Posts</span>
			<p class="sec-desc">의학, AI, 그리고 배움의 기록을 최근 순서대로 모았습니다.</p>
		</div>
		<div class="sec-line"></div>
		<a href="/blog" class="sec-all">전체 보기 →</a>
	</div>

	{gridPosts.length > 0 && (
		<div class="grid-wrap">
			<div class="post-grid" id="post-grid">
				{gridPosts.map((post) => (
					<a class="post-card" href={`/blog/${post.id}/`} data-cat={post.data.category ?? ''}>
						<div class="card-head">
							{post.data.category && <span class="card-cat">{post.data.category}</span>}
							<time class="card-date"><FormattedDate date={post.data.date} /></time>
						</div>
						<h3 class="card-title">{post.data.title}</h3>
						<p class="card-exc">{post.data.description}</p>
						<div class="card-foot">
							<span class="card-link">자세히 보기</span>
						</div>
					</a>
				))}
			</div>
		</div>
	)}

	<!-- Doctor AI 시리즈 섹션 -->
	<div class="sec-rule">
		<div class="sec-copy">
			<span class="sec-label">Doctor AI Series</span>
			<p class="sec-desc">임상 현장에서 AI를 안전하게 이해하고 활용하기 위한 의사를 위한 실무 교육</p>
		</div>
		<div class="sec-line"></div>
		<a href="/doctor-ai/" class="sec-all">시리즈 보기 →</a>
	</div>

	<div class="dai-wrap">
		<a class="dai-hero" href="/doctor-ai/">
			<div class="dai-hero-text">
				<span class="dai-eyebrow">Fundamentals · 5편 완성</span>
				<h2 class="dai-title">의사가 배우는 AI</h2>
				<p class="dai-desc">AI의 작동 원리부터 외래 진료 워크플로우 적용, 안전한 프롬프팅까지 — 임상의를 위한 첫 번째 AI 교육 시리즈</p>
				<span class="dai-cta">시리즈 전체 보기 →</span>
			</div>
			<div class="dai-hero-articles">
				<div class="dai-article-list">
					<span class="dai-item">01 · AI의 강점과 한계</span>
					<span class="dai-item">02 · 외래 진료 워크플로우</span>
					<span class="dai-item">03 · 안전한 의료 프롬프팅</span>
					<span class="dai-item">04 · 레지던트 교육과 연구</span>
					<span class="dai-item dai-item--more">+ 더 보기</span>
				</div>
			</div>
		</a>
	</div>
</Layout>

<style>
.dai-wrap {
	padding: 0 0 1.75rem;
}

.dai-hero {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 0;
	background: var(--bg2);
	border: 1px solid var(--rule);
	border-radius: 16px;
	overflow: hidden;
	text-decoration: none;
	color: inherit;
	transition: background 0.2s;
}

.dai-hero:hover {
	background: var(--bg3);
}

.dai-hero:active {
	background: var(--bg3);
}

.dai-hero-text {
	padding: 1.75rem 2rem;
	display: flex;
	flex-direction: column;
	gap: 0.625rem;
	border-right: 1px solid var(--rule);
}

.dai-eyebrow {
	font-size: 11px;
	font-weight: 700;
	letter-spacing: 0.8px;
	text-transform: uppercase;
	color: var(--pink);
}

.dai-title {
	font-family: var(--display);
	font-size: 1.75rem;
	font-weight: 800;
	color: var(--text);
	line-height: 1.2;
}

.dai-desc {
	font-size: 0.875rem;
	color: var(--t2);
	line-height: 1.55;
	flex: 1;
}

.dai-cta {
	display: inline-block;
	font-size: 0.8125rem;
	font-weight: 700;
	color: var(--pink);
	margin-top: 0.5rem;
}

.dai-hero:hover .dai-cta {
	text-decoration: underline;
}

.dai-hero-articles {
	padding: 1.75rem 1.5rem;
	display: flex;
	align-items: center;
}

.dai-article-list {
	display: flex;
	flex-direction: column;
	gap: 0.625rem;
	width: 100%;
}

.dai-item {
	display: block;
	padding: 0.625rem 1rem;
	background: var(--bg);
	border: 1px solid var(--rule2);
	border-radius: 8px;
	font-size: 0.8125rem;
	color: var(--t2);
	font-weight: 500;
}

.dai-item--more {
	color: var(--pink);
	font-weight: 700;
	background: transparent;
	border-color: transparent;
	padding-left: 1rem;
}

@media (max-width: 680px) {
	.dai-hero {
		grid-template-columns: 1fr;
	}
	.dai-hero-text {
		border-right: none;
		border-bottom: 1px solid var(--rule);
		padding: 1.75rem 1.5rem;
	}
	.dai-hero-articles {
		padding: 1.5rem;
	}
}
</style>
