---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getPublicSiteSettings } from '../lib/site-settings';

const siteSettings = await getPublicSiteSettings();
const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const configuredFeatured = siteSettings.featuredSlug
	? allPosts.find((post) => post.slug === siteSettings.featuredSlug || post.id.endsWith(`/${siteSettings.featuredSlug}`) || post.id === siteSettings.featuredSlug)
	: null;
const featuredPost = configuredFeatured || allPosts[0];
const rankedPosts = featuredPost
	? [featuredPost, ...allPosts.filter((post) => post.id !== featuredPost.id)]
	: allPosts;
const visiblePosts = rankedPosts.slice(0, 8);
const sidePosts = visiblePosts.slice(1, 3);
const gridPosts = visiblePosts.slice(3);
--- 

<Layout>
	{featuredPost ? (
		<div class="featured-wrap">
			<a class="featured-main" href={`/blog/${featuredPost.id}/`}>
				<div class="f-kicker">
					<span class="f-tag">{featuredPost.data.category ?? 'FEATURED'}</span>
					<span class="f-label">Latest Note</span>
				</div>
				<h1 class="f-title">{featuredPost.data.title}</h1>
				<p class="f-excerpt">{featuredPost.data.description}</p>
				<div class="f-foot">
					<div class="f-meta">
						<span class="f-meta-label">가장 최근에 발행한 글</span>
						<time class="f-date"><FormattedDate date={featuredPost.data.date} /></time>
					</div>
					<span class="read-link">읽기 →</span>
				</div>
			</a>
			<aside class="featured-side">
				<div class="side-head">
					<span class="side-head-label">더 읽어보기</span>
					<a href="/blog" class="side-head-link">아카이브</a>
				</div>
				{sidePosts.map((post) => (
					<a href={`/blog/${post.id}/`} class="side-post">
						{post.data.category && <span class="side-cat">{post.data.category}</span>}
						<h2 class="side-title">{post.data.title}</h2>
						<p class="side-exc">{post.data.description}</p>
						<span class="side-date"><FormattedDate date={post.data.date} /></span>
					</a>
				))}
			</aside>
		</div>
	) : (
		<div style="padding: 4rem 2rem; color: var(--t2); text-align: center;">
			아직 작성된 글이 없습니다.
		</div>
	)}

	<div class="sec-rule">
		<div class="sec-copy">
			<span class="sec-label">Recent Posts</span>
			<p class="sec-desc">의학, AI, 그리고 배움의 기록을 최근 순서대로 모았습니다.</p>
		</div>
		<div class="sec-line"></div>
		<a href="/blog" class="sec-all">전체 보기 →</a>
	</div>

	{gridPosts.length > 0 && (
		<div class="grid-wrap">
			<div class="post-grid" id="post-grid">
				{gridPosts.map((post) => (
					<a class="post-card" href={`/blog/${post.id}/`} data-cat={post.data.category ?? ''}>
						<div class="card-head">
							{post.data.category && <span class="card-cat">{post.data.category}</span>}
							<time class="card-date"><FormattedDate date={post.data.date} /></time>
						</div>
						<h3 class="card-title">{post.data.title}</h3>
						<p class="card-exc">{post.data.description}</p>
						<div class="card-foot">
							<span class="card-link">자세히 보기</span>
						</div>
					</a>
				))}
			</div>
		</div>
	)}
</Layout>
