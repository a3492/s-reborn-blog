---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { CATEGORIES, SITE_DESCRIPTION } from '../../consts';
import { getPublicSiteSettings } from '../../lib/site-settings';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const siteSettings = await getPublicSiteSettings();

const categoryLabel = (id: string) => CATEGORIES.find((c) => c.id === id)?.label ?? id;
const countsByCategory = posts.reduce<Record<string, number>>((acc, post) => {
	const c = post.data.category;
	if (c) acc[c] = (acc[c] ?? 0) + 1;
	return acc;
}, {});
const categoryCounts = Object.entries(countsByCategory)
	.map(([id, count]) => ({ id, label: categoryLabel(id), count }))
	.sort((a, b) => b.count - a.count);
const latestDate = posts[0]?.data.date;
---

<Layout title="Blog" description={siteSettings.siteDescription || SITE_DESCRIPTION}>
	<section class="blog-list-section">
		<div class="blog-list-header">
			<div>
				<p class="blog-list-kicker">Archive</p>
				<h1 class="blog-list-title">전체 글</h1>
          <p class="blog-list-subtitle">{siteSettings.siteTitle}의 전체 글 아카이브입니다.</p>
			</div>
			<span class="blog-count">{posts.length}개</span>
		</div>

		<!-- 데스크탑 카테고리 칩 필터 -->
		<div class="blog-cat-filter" id="blog-cat-filter">
			<button class="blog-cat-chip blog-cat-chip--active" data-cat="">전체 <span class="blog-cat-count">{posts.length}</span></button>
			{categoryCounts.map((category) => (
				<button class="blog-cat-chip" data-cat={category.id}>
					{category.label} <span class="blog-cat-count">{category.count}</span>
				</button>
			))}
		</div>

		<!-- 모바일용 카테고리 필터 -->
		<div class="blog-mobile-filter">
			<select id="category-filter" class="blog-category-select">
				<option value="">전체 글 보기</option>
				{categoryCounts.map((category) => (
					<option value={category.id}>{category.label} ({category.count})</option>
				))}
			</select>
		</div>

		<div class="blog-summary-row">
			<div class="blog-summary-card">
				<span class="blog-summary-label">Latest</span>
				<strong class="blog-summary-value"><FormattedDate date={latestDate} /></strong>
				<p class="blog-summary-copy">가장 최근 글의 발행일을 표시합니다.</p>
			</div>
			<div class="blog-summary-card">
				<span class="blog-summary-label">Topics</span>
				<strong class="blog-summary-value">{categoryCounts.length}</strong>
				<p class="blog-summary-copy">현재 활성화된 카테고리 수입니다.</p>
			</div>
			<div class="blog-summary-card blog-summary-wide">
				<span class="blog-summary-label">Top categories</span>
				<div class="blog-summary-chips">
					{categoryCounts.slice(0, 3).map((category) => (
						<span class="blog-summary-chip">{category.label} · {category.count}</span>
					))}
				</div>
			</div>
		</div>

		<ul class="blog-list">
			{posts.map((post) => (
				<li>
					<a href={`/blog/${post.id}/`} class="blog-item">
						<div class="blog-item-meta-row">
							{post.data.category && (
								<span class="card-cat" data-cat-id={post.data.category}>
									{CATEGORIES.find(c => c.id === post.data.category)?.label ?? post.data.category}
								</span>
							)}
							<span class="blog-item-arrow">읽기 →</span>
						</div>
						<h3 class="blog-item-title">{post.data.title}</h3>
						{post.data.description && (
							<p class="blog-item-desc">{post.data.description}</p>
						)}
						<div class="blog-item-foot">
							<span class="blog-item-date">
								<FormattedDate date={post.data.date} />
							</span>
						</div>
					</a>
				</li>
			))}
		</ul>
	</section>
</Layout>

<style>
/* 데스크탑 카테고리 칩 필터 */
.blog-cat-filter {
	display: flex;
	flex-wrap: wrap;
	gap: 0.5rem;
	margin: 1.25rem 0 1rem;
}

.blog-cat-chip {
	padding: 0.35rem 0.75rem;
	background: var(--bg2);
	border: 1px solid var(--rule);
	border-radius: 999px;
	font-size: 0.78rem;
	font-weight: 500;
	color: var(--t2);
	cursor: pointer;
	transition: background 0.15s, color 0.15s, border-color 0.15s;
	white-space: nowrap;
}

.blog-cat-chip:hover {
	background: var(--bg3);
	color: var(--text);
}

.blog-cat-chip--active {
	background: var(--pink);
	border-color: var(--pink);
	color: #fff;
}

.blog-cat-count {
	opacity: 0.75;
	font-weight: 400;
}

/* 모바일 카테고리 필터 */
.blog-mobile-filter {
	display: none;
	margin: 1rem 0;
}

.blog-category-select {
	width: 100%;
	padding: 0.75rem;
	border: 1px solid var(--rule);
	border-radius: 6px;
	font-size: 0.95rem;
	background: var(--bg2);
	color: var(--text);
	cursor: pointer;
}

@media (max-width: 768px) {
	.blog-cat-filter {
		display: none;
	}
	.blog-mobile-filter {
		display: block;
	}
	.blog-summary-row {
		display: none;
	}
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
	const items = document.querySelectorAll('.blog-list li');

	function filterByCat(catId: string) {
		items.forEach((item) => {
			const catEl = item.querySelector('.card-cat');
			if (!catId) {
				(item as HTMLElement).style.display = '';
			} else {
				const postCat = catEl?.getAttribute('data-cat-id');
				(item as HTMLElement).style.display = postCat === catId ? '' : 'none';
			}
		});
	}

	// 데스크탑 칩 필터
	const chipFilter = document.getElementById('blog-cat-filter');
	if (chipFilter) {
		chipFilter.addEventListener('click', (e) => {
			const btn = (e.target as HTMLElement).closest('.blog-cat-chip') as HTMLButtonElement | null;
			if (!btn) return;
			chipFilter.querySelectorAll('.blog-cat-chip').forEach(c => c.classList.remove('blog-cat-chip--active'));
			btn.classList.add('blog-cat-chip--active');
			filterByCat(btn.dataset.cat ?? '');
		});
	}

	// 모바일 select 필터
	const select = document.getElementById('category-filter') as HTMLSelectElement | null;
	if (select) {
		select.addEventListener('change', () => filterByCat(select.value));
	}

	// URL ?category= 파라미터로 초기 필터
	const params = new URLSearchParams(window.location.search);
	const initCat = params.get('category') || '';
	if (initCat) {
		filterByCat(initCat);
		// 칩 활성화
		if (chipFilter) {
			chipFilter.querySelectorAll('.blog-cat-chip').forEach(c => c.classList.remove('blog-cat-chip--active'));
			const target = chipFilter.querySelector(`[data-cat="${initCat}"]`) as HTMLElement | null;
			if (target) target.classList.add('blog-cat-chip--active');
		}
		if (select) select.value = initCat;
	}
});
</script>
