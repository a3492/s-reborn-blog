---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { CATEGORIES, SITE_DESCRIPTION } from '../../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Blog" description={SITE_DESCRIPTION}>
	<section class="blog-list-section">
		<div class="blog-list-header">
			<h1 class="blog-list-title">전체 글</h1>
			<span class="blog-count">{posts.length}개</span>
		</div>

		<ul class="blog-list">
			{posts.map((post) => (
				<li>
					<a href={`/blog/${post.id}/`} class="blog-item">
						{post.data.category && (
							<span class="card-cat">
								{CATEGORIES.find(c => c.id === post.data.category)?.label ?? post.data.category}
							</span>
						)}
						<h3 class="blog-item-title">{post.data.title}</h3>
						{post.data.description && (
							<p class="blog-item-desc">{post.data.description}</p>
						)}
						<span class="blog-item-date">
							<FormattedDate date={post.data.date} />
						</span>
					</a>
				</li>
			))}
		</ul>
	</section>
</Layout>

<style>
	.blog-list-section {
		padding: 2rem 1.5rem 4rem;
		max-width: 760px;
		margin: 0 auto;
	}

	.blog-list-header {
		display: flex;
		align-items: baseline;
		gap: 0.75rem;
		margin-bottom: 1.75rem;
		padding-bottom: 0.75rem;
		border-bottom: 1px solid var(--rule);
	}

	.blog-list-title {
		font-size: 1.4rem;
		font-weight: 700;
		color: var(--text);
		margin: 0;
	}

	.blog-count {
		font-size: 0.82rem;
		color: var(--t3);
	}

	.blog-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.blog-item {
		display: block;
		padding: 1.1rem 1rem;
		border-bottom: 1px solid var(--rule);
		text-decoration: none;
		transition: background 0.15s;
		border-radius: 6px;
	}

	.blog-item:hover {
		background: rgba(255, 255, 255, 0.04);
	}

	.blog-item-title {
		font-size: 1rem;
		font-weight: 600;
		color: var(--text);
		margin: 0.3rem 0 0.4rem;
		line-height: 1.4;
		transition: color 0.15s;
	}

	.blog-item:hover .blog-item-title {
		color: var(--accent);
	}

	.blog-item-desc {
		font-size: 0.875rem;
		color: var(--t2);
		margin: 0 0 0.4rem;
		line-height: 1.5;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.blog-item-date {
		font-size: 0.78rem;
		color: var(--t3);
	}

	@media (max-width: 480px) {
		.blog-list-section {
			padding: 1.25rem 0.75rem 3rem;
		}
		.blog-list-title {
			font-size: 1.2rem;
		}
	}
</style>
