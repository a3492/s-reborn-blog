---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { CATEGORIES, MENU_GROUPS, SITE_DESCRIPTION } from '../../consts';
import { getPublicSiteSettings } from '../../lib/site-settings';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const siteSettings = await getPublicSiteSettings();

const categoryLabel = (id: string) => CATEGORIES.find((c) => c.id === id)?.label ?? id;

const countsByCategory = posts.reduce<Record<string, number>>((acc, post) => {
	const c = post.data.category;
	if (c) acc[c] = (acc[c] ?? 0) + 1;
	return acc;
}, {});
---

<Layout title="Blog" description={siteSettings.siteDescription || SITE_DESCRIPTION}>
	<div class="blog-layout">

		<!-- ── 좌측 네비게이션 ── -->
		<nav class="blog-nav" id="blog-nav" aria-label="카테고리 내비게이션">

			<!-- 모바일 토글 -->
			<button class="blog-nav-mobile-toggle" id="blog-nav-toggle" aria-expanded="false">
				<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
					<path d="M2 4h12M2 8h12M2 12h12"/>
				</svg>
				<span>카테고리</span>
				<svg class="blog-nav-mobile-chevron" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M3 1.5l4 3.5-4 3.5"/></svg>
			</button>

			<div class="blog-nav-body" id="blog-nav-body">
				<!-- 전체 -->
				<button class="blog-nav-all blog-nav-all--active" id="nav-all" data-cat="" data-label="전체 글">
					<span class="blog-nav-all-label">⊞ 전체 글</span>
					<span class="blog-nav-count">{posts.length}</span>
				</button>

				<div class="blog-nav-divider"></div>

				<!-- 그룹 -->
				{MENU_GROUPS.map((group) => (
					<div class="blog-nav-group" data-group={group.id}>
						<button class="blog-nav-group-hd" data-toggle={group.id}>
							<span class="blog-nav-group-icon">{group.icon}</span>
							<span class="blog-nav-group-label">{group.label}</span>
							<svg class="blog-nav-chevron" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
								<path d="M3 1.5l4 3.5-4 3.5"/>
							</svg>
						</button>
						<div class="blog-nav-group-body">
							{group.cats.map((catId) => {
								const cat = CATEGORIES.find((c) => c.id === catId);
								if (!cat) return null;
								const count = countsByCategory[catId] ?? 0;
								return (
									<button
										class="blog-nav-item"
										data-cat={catId}
										data-label={cat.label}
									>
										<span class="blog-nav-item-label">{cat.label}</span>
										<span class="blog-nav-item-count">{count}</span>
									</button>
								);
							})}
						</div>
					</div>
				))}
			</div>
		</nav>

		<!-- ── 컨텐츠 영역 ── -->
		<main class="blog-content">
			<div class="blog-content-hd">
				<h1 class="blog-content-title" id="blog-content-title">전체 글</h1>
				<span class="blog-content-count" id="blog-content-count">{posts.length}개</span>
			</div>

			<div class="blog-card-grid" id="blog-card-grid">
				{posts.map((post) => (
					<a
						href={`/blog/${post.id}/`}
						class="blog-card"
						data-cat={post.data.category ?? ''}
						data-title={post.data.title}
						data-desc={post.data.description ?? ''}
						data-tags={(post.data.tags ?? []).join(' ')}
						data-difficulty={post.data.difficulty ?? ''}
					>
						{post.data.category && (
							<span class="blog-card-cat">{categoryLabel(post.data.category)}</span>
						)}
						<h3 class="blog-card-title">{post.data.title}</h3>
						{post.data.description && (
							<p class="blog-card-desc">{post.data.description}</p>
						)}
						<span class="blog-card-date"><FormattedDate date={post.data.date} /></span>
					</a>
				))}
			</div>
		</main>
	</div>
</Layout>

<script>
document.addEventListener('DOMContentLoaded', () => {
	const cards = document.querySelectorAll<HTMLElement>('.blog-card');
	const navAll = document.getElementById('nav-all')!;
	const navItems = document.querySelectorAll<HTMLButtonElement>('.blog-nav-item');
	const groupHeaders = document.querySelectorAll<HTMLButtonElement>('.blog-nav-group-hd');
	const contentTitle = document.getElementById('blog-content-title')!;
	const contentCount = document.getElementById('blog-content-count')!;
	const mobileToggle = document.getElementById('blog-nav-toggle')!;
	const navBody = document.getElementById('blog-nav-body')!;

	// ── 모바일 토글 ──
	mobileToggle.addEventListener('click', () => {
		const open = navBody.classList.toggle('is-open');
		mobileToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
	});

	// ── 그룹 펼치기/접기 ──
	groupHeaders.forEach((hd) => {
		hd.addEventListener('click', () => {
			const group = hd.closest('.blog-nav-group')!;
			group.classList.toggle('is-open');
		});
	});

	// ── 필터 함수 ──
	function filterByCat(catId: string, label: string) {
		let visible = 0;
		cards.forEach((card) => {
			const match = !catId || card.dataset.cat === catId;
			card.style.display = match ? '' : 'none';
			if (match) visible++;
		});
		contentTitle.textContent = label;
		contentCount.textContent = `${visible}개`;
	}

	// ── 활성 상태 설정 ──
	function setActive(target: HTMLButtonElement | null, isAll: boolean) {
		navAll.classList.toggle('blog-nav-all--active', isAll);
		navItems.forEach((i) => i.classList.remove('blog-nav-item--active'));
		if (!isAll && target) target.classList.add('blog-nav-item--active');
	}

	// ── 전체 클릭 ──
	navAll.addEventListener('click', () => {
		filterByCat('', '전체 글');
		setActive(null, true);
	});

	// ── 카테고리 클릭 ──
	navItems.forEach((item) => {
		item.addEventListener('click', () => {
			const cat = item.dataset.cat ?? '';
			const label = item.dataset.label ?? cat;
			filterByCat(cat, label);
			setActive(item, false);
			// 부모 그룹 자동 펼치기
			item.closest('.blog-nav-group')?.classList.add('is-open');
			// 모바일: 메뉴 닫기
			navBody.classList.remove('is-open');
			mobileToggle.setAttribute('aria-expanded', 'false');
		});
	});

	// ── 시맨틱 검색 — 의미 확장 사전 ──
	const CONCEPT_MAP: Record<string, string[]> = {
		'입문':     ['beginner','초보','기초','처음','시작','도구소개','쉬운','faq','설치'],
		'초보':     ['beginner','입문','기초','처음','쉬운','시작'],
		'기초':     ['beginner','입문','초보','기본','처음'],
		'쉬운':     ['beginner','입문','초보','기초','간단'],
		'시작':     ['beginner','입문','초보','설치','처음'],
		'처음':     ['beginner','입문','초보','기초','시작'],
		'심화':     ['advanced','고급','전문','intermediate'],
		'고급':     ['advanced','심화','전문'],
		'중급':     ['intermediate','중간'],
		'전문':     ['advanced','심화','고급','의료'],
		'비용':     ['무료','유료','가격','요금','api','구독','결제','cost'],
		'무료':     ['free','비용','가격','요금'],
		'가격':     ['비용','무료','유료','요금','구독'],
		'유료':     ['비용','가격','결제','구독'],
		'돈':       ['비용','가격','요금','무료','유료'],
		'요금':     ['비용','가격','무료','유료','구독'],
		'구독':     ['비용','가격','유료','결제','플랜'],
		'법':       ['법적','법률','의료법','규정','합법','책임','허가'],
		'법적':     ['법','법률','의료법','규정','합법','책임'],
		'법률':     ['법','법적','의료법','규정','책임'],
		'규정':     ['법','법적','법률','의료법','허가'],
		'책임':     ['법적','의사','오류','과실','법률'],
		'윤리':     ['법적','도덕','책임','동의','허가','환자'],
		'보안':     ['개인정보','데이터','보호','gdpr','암호화'],
		'개인정보': ['보안','데이터','보호','gdpr','환자'],
		'데이터':   ['개인정보','보안','보호','환자','의료'],
		'진단':     ['ai','의료','의사','임상','병원'],
		'의사':     ['의료','임상','진료','병원','처방'],
		'병원':     ['의료','임상','의사','진료'],
		'환자':     ['의료','임상','진료','개인정보'],
		'도구':     ['툴','소프트웨어','ai','앱','플랫폼'],
		'설치':     ['install','셋업','시작','준비'],
		'ai':       ['인공지능','llm','gpt','claude','생성형'],
		'자동화':   ['workflow','파이프라인','에이전트','오케스트레이션'],
		'글쓰기':   ['문서','기록','작성','노트','보고서'],
		'요약':     ['정리','분석','추출','핵심'],
		'코딩':     ['개발','프로그래밍','코드','소프트웨어'],
		'개발':     ['코딩','프로그래밍','소프트웨어','앱'],
		'터미널':   ['cli','명령어','설치','개발'],
	};

	function expandQuery(query: string): string[] {
		const q = query.toLowerCase().trim();
		const terms = new Set([q]);
		for (const [key, synonyms] of Object.entries(CONCEPT_MAP)) {
			const k = key.toLowerCase();
			if (q.includes(k) || k.includes(q)) {
				synonyms.forEach(s => terms.add(s.toLowerCase()));
				terms.add(k);
			}
			if (synonyms.some(s => { const sl = s.toLowerCase(); return q.includes(sl) || sl.includes(q); })) {
				terms.add(k);
				synonyms.forEach(s => terms.add(s.toLowerCase()));
			}
		}
		return [...terms];
	}

	function detectIntent(query: string): string | null {
		const q = query.toLowerCase();
		if (['입문','초보','기초','쉬운','처음','시작','beginner'].some(t => q.includes(t))) return 'beginner';
		if (['심화','고급','전문','advanced'].some(t => q.includes(t))) return 'advanced';
		if (['중급','intermediate'].some(t => q.includes(t))) return 'intermediate';
		return null;
	}

	function scoreCard(card: HTMLElement, terms: string[], intent: string | null): number {
		const title = (card.dataset.title ?? '').toLowerCase();
		const desc  = (card.dataset.desc ?? '').toLowerCase();
		const tags  = (card.dataset.tags ?? '').toLowerCase();
		const diff  = card.dataset.difficulty ?? '';
		const cat   = (card.dataset.cat ?? '').toLowerCase();
		let score = 0;
		for (const term of terms) {
			if (title.includes(term)) score += 10;
			if (tags.includes(term))  score += 8;
			if (desc.includes(term))  score += 5;
			if (cat.includes(term))   score += 3;
		}
		if (intent && diff === intent) score += 15;
		return score;
	}

	function filterBySearch(query: string) {
		const terms  = expandQuery(query);
		const intent = detectIntent(query);
		const grid   = document.getElementById('blog-card-grid')!;

		const scored = Array.from(cards).map(card => ({
			card,
			score: scoreCard(card as HTMLElement, terms, intent),
		}));

		// 점수 있는 카드만, 점수 순으로 정렬
		const matches = scored.filter(s => s.score > 0).sort((a, b) => b.score - a.score);
		const noMatch = scored.filter(s => s.score === 0);

		// 순서 재배치 + visibility
		matches.forEach(({ card }) => { (card as HTMLElement).style.display = ''; grid.appendChild(card); });
		noMatch.forEach(({ card }) => { (card as HTMLElement).style.display = 'none'; });

		contentTitle.textContent = `"${query}" 검색 결과`;
		contentCount.textContent = `${matches.length}개`;
		setActive(null, false);
	}

	// ── URL ?q= 검색 / ?category= 카테고리 초기 필터 ──
	const params = new URLSearchParams(window.location.search);
	const initQ   = params.get('q') ?? '';
	const initCat = params.get('category') ?? '';

	if (initQ) {
		filterBySearch(initQ);
	} else if (initCat) {
		const target = [...navItems].find((i) => i.dataset.cat === initCat);
		if (target) target.click();
	}
});
</script>
