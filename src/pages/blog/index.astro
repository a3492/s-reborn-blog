---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { CATEGORIES, SITE_DESCRIPTION } from '../../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Blog" description={SITE_DESCRIPTION}>
	<section class="blog-list-section">
		<div class="blog-list-header">
			<div>
				<p class="blog-list-kicker">Archive</p>
				<h1 class="blog-list-title">전체 글</h1>
			</div>
			<span class="blog-count">{posts.length}개</span>
		</div>

		<ul class="blog-list">
			{posts.map((post) => (
				<li>
					<a href={`/blog/${post.id}/`} class="blog-item">
						<div class="blog-item-meta-row">
							{post.data.category && (
								<span class="card-cat">
									{CATEGORIES.find(c => c.id === post.data.category)?.label ?? post.data.category}
								</span>
							)}
							<span class="blog-item-arrow">읽기 →</span>
						</div>
						<h3 class="blog-item-title">{post.data.title}</h3>
						{post.data.description && (
							<p class="blog-item-desc">{post.data.description}</p>
						)}
						<div class="blog-item-foot">
							<span class="blog-item-date">
								<FormattedDate date={post.data.date} />
							</span>
						</div>
					</a>
				</li>
			))}
		</ul>
	</section>
</Layout>

<style>
	.blog-list-section {
		padding: 2rem 1.5rem 4rem;
		max-width: 820px;
		margin: 0 auto;
	}

	.blog-list-header {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1.75rem;
		padding: 0 0.25rem 0.95rem;
		border-bottom: 1px solid var(--rule);
	}

	.blog-list-kicker {
		margin: 0 0 0.35rem;
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--pink);
	}

	.blog-list-title {
		font-size: clamp(1.35rem, 2vw, 1.8rem);
		font-family: var(--display);
		font-weight: 700;
		letter-spacing: -0.02em;
		color: var(--text);
		margin: 0;
	}

	.blog-count {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 3rem;
		height: 2rem;
		padding: 0 0.8rem;
		border-radius: 999px;
		background: var(--bg2);
		border: 1px solid var(--rule);
		font-size: 0.82rem;
		color: var(--t3);
	}

	.blog-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
	}

	.blog-item {
		display: block;
		padding: 1.15rem 1.15rem 1.05rem;
		border: 1px solid var(--rule2);
		border-radius: 18px;
		text-decoration: none;
		background: rgba(250, 248, 245, 0.72);
		transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
	}

	.blog-item:hover,
	.blog-item:focus-visible {
		background: var(--bg3);
		border-color: rgba(184, 149, 106, 0.3);
		box-shadow: 0 14px 30px rgba(28, 25, 23, 0.06);
		transform: translateY(-2px);
		outline: none;
	}

	.blog-item-meta-row,
	.blog-item-foot {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
	}

	.blog-item-arrow {
		font-size: 0.82rem;
		font-weight: 600;
		color: var(--pink);
		transition: transform 0.18s ease, color 0.18s ease;
	}

	.blog-item-title {
		font-size: 1.08rem;
		font-family: var(--display);
		font-weight: 700;
		letter-spacing: -0.02em;
		color: var(--text);
		margin: 0.5rem 0 0.42rem;
		line-height: 1.42;
		transition: color 0.18s ease;
	}

	.blog-item:hover .blog-item-title,
	.blog-item:focus-visible .blog-item-title {
		color: #8C6D45;
	}

	.blog-item:hover .blog-item-arrow,
	.blog-item:focus-visible .blog-item-arrow {
		color: #8C6D45;
		transform: translateX(3px);
	}

	.blog-item-desc {
		font-size: 0.92rem;
		color: var(--t2);
		margin: 0 0 0.7rem;
		line-height: 1.7;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.blog-item-date {
		font-size: 0.8rem;
		color: var(--t3);
	}

	@media (max-width: 480px) {
		.blog-list-section {
			padding: 1.25rem 0.75rem 3rem;
		}

		.blog-list-header,
		.blog-item-meta-row,
		.blog-item-foot {
			align-items: flex-start;
			flex-direction: column;
		}

		.blog-item {
			padding: 1rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.blog-item,
		.blog-item-title,
		.blog-item-arrow {
			transition: none !important;
		}
	}
</style>