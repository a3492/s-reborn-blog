---
import Layout from '../../layouts/Layout.astro';
import { SITE_BRAND } from '../../consts';
---

<Layout
	title={SITE_BRAND.labDisplayName}
	description={`${SITE_BRAND.doctorAiAcademyDisplayName}와 ${SITE_BRAND.clinicBlogDisplayName}를 모은 허브입니다.`}
>
	<div class="lab-page">
		<header class="lab-page-head">
			<h1>{SITE_BRAND.labDisplayName}</h1>
			<p class="lab-page-lead">
				임상·AI·기록을 모은 실험실입니다. 아래에서 바로 이동할 수 있습니다.
			</p>
		</header>

		<div class="lab-hub-grid">
			<a class="lab-hub-card" href="https://s-reborn-doctor-ai-academy.pages.dev/" target="_blank" rel="noopener noreferrer">
				<span class="lab-hub-icon" aria-hidden="true">🩺</span>
				<h2 class="lab-hub-title">{SITE_BRAND.doctorAiAcademyDisplayName}</h2>
				<p class="lab-hub-desc">
					Fundamentals, Prompts, Cases, Tools — 임상의를 위한 AI 교육 시리즈.
				</p>
				<span class="lab-hub-cta">Academy로 이동 →</span>
			</a>
			<a class="lab-hub-card" href="https://s-reborn-clinic.pages.dev/blog/" target="_blank" rel="noopener noreferrer">
				<span class="lab-hub-icon" aria-hidden="true">🏥</span>
				<h2 class="lab-hub-title">{SITE_BRAND.clinicBlogDisplayName}</h2>
				<p class="lab-hub-desc">
					에스리본 클리닉 블로그 — 진료·시술·건강 정보를 다룹니다.
				</p>
				<span class="lab-hub-cta">클리닉으로 이동 →</span>
			</a>
		</div>
	</div>
</Layout>
