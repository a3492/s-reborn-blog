---
import '../styles/design.css';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Topbar from '../components/Topbar.astro';
import { getPublicSiteSettings } from '../lib/site-settings';

const siteSettings = await getPublicSiteSettings();
const siteTitle = siteSettings.siteTitle;
const aboutIntro = siteSettings.aboutIntro;
const socialLinks = Object.entries(siteSettings.socialLinks || {}).filter(([, url]) => String(url || '').trim());
const aboutIntroHtml = (aboutIntro || '의사로 시작해서 AI 연구자가 되어가는 중입니다.\n\n진료실에서 환자를 만나면서, AI가 의료를 어떻게 바꿀 수 있을지 끊임없이 고민합니다. 의학·기술·배움이 교차하는 지점에서 새로운 가능성을 탐구하고, 그 여정을 이 블로그에 솔직하게 기록합니다.\n\n거창한 답보다는 작은 발견을 나누고 싶어서 글을 씁니다.')
  .split(/\n\s*\n/)
  .map((paragraph) => paragraph.trim())
  .filter(Boolean)
  .join('<br /><br />');
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead
      title={`About — ${siteTitle}`}
      description="에스리본의원 홍대점 대표원장 김도위 원장의 소개 페이지입니다."
      image={siteSettings.defaultOgImage || undefined}
      siteTitle={siteTitle}
    />
	</head>
	<body>
		<Topbar siteTitle={siteTitle} />

		<div class="about-wrap">
			<div class="about-hero">
				<img class="about-avatar" src="/profile.jpg" alt="김도위 원장" />
				<h1>김도위 원장</h1>
				<p class="about-role">가정의학과 전문의 · 에스리본의원 홍대점 대표원장</p>
				<div class="about-tags">
					<span class="about-tag">#가정의학과</span>
					<span class="about-tag">#미용의학</span>
					<span class="about-tag">#AI의료</span>
					<span class="about-tag">#평생학습</span>
				</div>
			</div>

			<section class="about-section">
				<h2>안녕하세요</h2>
				<p class="about-intro-text">
					<Fragment set:html={aboutIntroHtml} />
				</p>
			</section>

			<section class="about-section">
				<h2>현재</h2>
				<div class="about-current-card">
					<div class="about-current-title">에스리본의원 홍대점 대표원장</div>
					<div class="about-current-sub">가정의학과 전문의 · 미용의학 전반</div>
				</div>
				<div class="about-current-card">
					<div class="about-current-title">대한필러학회 학술이사</div>
					<div class="about-current-sub"></div>
				</div>
				<div class="about-current-card">
					<div class="about-current-title">한국피부비만성형학회 학술이사</div>
					<div class="about-current-sub"></div>
				</div>
				<div class="about-current-card">
					<div class="about-current-title">D&PS 미용의학잡지 연재</div>
					<div class="about-current-sub">우리가 몰랐던 다양한 사실들을 꼬리에 꼬리를 물면서 의학 지식과 연결시키는 글을 씁니다</div>
				</div>
				<div class="about-current-card">
					<div class="about-current-title">한국 AI 리터러시 협회 의료분과 전문위원</div>
					<div class="about-current-sub">의료인의 AI 활용 역량을 높이기 위한 활동</div>
				</div>
			</section>

			<section class="about-section">
				<h2>이력</h2>
				<ul class="about-timeline">
					<li>
						<span class="about-year">학력</span>
						한양대학교 의과대학 졸업
					</li>
					<li>
						<span class="about-year">수련</span>
						한양대학교병원 인턴 수료
					</li>
					<li>
						<span class="about-year">수련</span>
						서울의료원 레지던트 수료 (가정의학과)
					</li>
					<li>
						<span class="about-year">수상</span>
						삼성메디슨 의료기기 공모전 전문가 부문 <strong>대상</strong>
					</li>
					<li>
						<span class="about-year">개발</span>
						'부스트리(Boostree)' 병원 프로그램 개발팀 활동
					</li>
				</ul>
			</section>

			<section class="about-section">
				<h2>병원 위치</h2>
				<div class="about-map-card">
					<div class="about-map-info">
						<div class="about-clinic-name">에스리본의원 홍대점</div>
						<div class="about-clinic-addr">
							서울 마포구 홍대 인근<br />
							🕐 진료시간 네이버 지도에서 확인
						</div>
					</div>
					<a href="https://naver.me/5GpoDRLh" target="_blank" rel="noopener noreferrer" class="about-map-btn">
						📍 네이버 지도 열기 →
					</a>
				</div>
			</section>

      {socialLinks.length > 0 && (
        <section class="about-section">
          <h2>연결</h2>
          <div class="about-socials">
            {socialLinks.map(([label, url]) => (
              <a href={url} target="_blank" rel="noreferrer" class="about-social-link">
                <span>{label}</span>
                <span>열기 ↗</span>
              </a>
            ))}
          </div>
        </section>
      )}
		</div>

		<Footer siteTitle={siteTitle} socialLinks={siteSettings.socialLinks} />
	</body>
</html>
